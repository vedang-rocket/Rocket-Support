# .env.example — Rocket.new Project Environment Variables
# Copy to .env and fill in your values
# NOTE: Rocket generates .env (not .env.local) — both work in Next.js

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY
# ^ NEVER prefix with NEXT_PUBLIC_ — server-only, bypasses all RLS

# ─── Stripe (if project uses payments) ────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# ^ Never NEXT_PUBLIC_ — server-only
STRIPE_WEBHOOK_SECRET=whsec_...
# ^ Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# ^ Different value for test vs live environments
STRIPE_PRICE_ID=price_...
# ^ Get from: Stripe Dashboard → Products → your product → Price ID
# ^ Must recreate in live mode — test price IDs don't work in production

# ─── App URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# ^ Production: https://your-app.netlify.app or custom domain
# ^ Used in: Stripe redirect URLs, Supabase redirect URLs, email links

# ─── Email (if project sends emails) ──────────────────────────────────────
RESEND_API_KEY=re_...
# ^ Get from: resend.com → API Keys
# ^ Server-only — never NEXT_PUBLIC_

# ─── AI APIs (if project uses AI features) ────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
PERPLEXITY_API_KEY=pplx-...

# ─── Analytics (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_ADSENSE_ID=ca-pub-...

# ─── Notes ─────────────────────────────────────────────────────────────────
# Netlify: Add all vars manually in Site Settings → Environment Variables
# .env is NOT auto-synced to Netlify — you must add each variable manually
# After adding Netlify vars: trigger a new deploy for them to take effect
# Test keys (sk_test_, pk_test_) only work in Stripe test mode
# Live keys (sk_live_, pk_live_) required for real payments in production
