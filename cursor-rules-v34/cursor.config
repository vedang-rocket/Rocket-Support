{
  "chunking": {
    "max_files": 50,
    "max_files_per_query": 10,
    "exclude_dirs": [
      "node_modules",
      ".next",
      "out",
      "dist",
      "build",
      ".git",
      "coverage",
      "supabase/.branches",
      "supabase/.temp"
    ],
    "priority_dirs": [
      "app",
      "lib",
      "components",
      "supabase/migrations"
    ]
  },
  "indexing": {
    "include_extensions": [
      ".ts",
      ".tsx",
      ".js",
      ".jsx",
      ".sql",
      ".md"
    ],
    "exclude_extensions": [
      ".log",
      ".lock",
      ".map"
    ],
    "max_file_size_kb": 100
  },
  "context": {
    "max_auto_include_files": 5,
    "prefer_open_files": true,
    "prefer_recently_edited": true
  },
  "budget": {
    "monthly_limit_usd": 50,
    "warning_threshold_pct": 80,
    "block_threshold_pct": 100,
    "slack_alert": false,
    "_comment": "Edit monthly_limit_usd to your budget. Set slack_alert: true and SLACK_WEBHOOK_URL env var for Slack notifications."
  }
}