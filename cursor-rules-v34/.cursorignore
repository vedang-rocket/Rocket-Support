# .cursorignore — Files Cursor should NOT index or read
# Prevents: secret exposure, context pollution, slow indexing

# Secrets — NEVER index these
.env.local
.env.production
.env.*.local
*.pem
*.key
*.cert

# Build output — irrelevant, large
.next/
out/
dist/
build/

# Dependencies — massive, useless for context
node_modules/
.npm/
.pnp/
.pnp.js

# Supabase local — not needed for fixing user projects
supabase/.branches/
supabase/.temp/

# Cursor internal — don't index logs
.cursor/agent-log.txt
.cursor/sessions/
.cursor/security-log.md
.cursor/tech-debt-log.md

# Version control
.git/

# OS files
.DS_Store
Thumbs.db

# Test coverage reports
coverage/
.nyc_output/

# Cache
.cache/
*.cache

# Logs
*.log
npm-debug.log*
