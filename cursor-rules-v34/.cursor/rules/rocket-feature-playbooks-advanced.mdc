## Playbook 8: Public API Endpoint with Rate Limiting

```typescript
// app/api/public/data/route.ts
import { NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase/server'

const RATE_LIMIT = 100 // requests per hour
const rateLimitMap = new Map<string, { count: number; reset: number }>()

export async function GET(request: Request) {
  // Rate limit by IP
  const ip = request.headers.get('x-forwarded-for') ?? 'unknown'
  const now = Date.now()
  const hourMs = 60 * 60 * 1000

  const rateData = rateLimitMap.get(ip) ?? { count: 0, reset: now + hourMs }
  if (now > rateData.reset) { rateData.count = 0; rateData.reset = now + hourMs }
  rateData.count++
  rateLimitMap.set(ip, rateData)

  if (rateData.count > RATE_LIMIT) {
    return NextResponse.json({ error: 'Rate limit exceeded' }, {
      status: 429,
      headers: { 'Retry-After': String(Math.ceil((rateData.reset - now) / 1000)) }
    })
  }

  // Validate API key (optional)
  const apiKey = request.headers.get('x-api-key')
  if (!apiKey) return NextResponse.json({ error: 'API key required' }, { status: 401 })

  const supabase = await createClient()
  const { data: keyRecord } = await supabase
    .from('api_keys')
    .select('user_id')
    .eq('key', apiKey)
    .single()

  if (!keyRecord) return NextResponse.json({ error: 'Invalid API key' }, { status: 401 })

  const { data } = await supabase.from('public_data').select('*').limit(100)
  return NextResponse.json(data)
}
```

