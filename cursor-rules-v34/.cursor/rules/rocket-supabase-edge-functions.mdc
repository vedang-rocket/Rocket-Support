## Error Handling — Production Patterns

```typescript
Deno.serve(async (req: Request) => {
  // Catch unhandled promise rejections (async errors that escape try/catch)
  addEventListener('unhandledrejection', (event) => {
    console.error('Unhandled rejection:', event.reason)
    event.preventDefault()
  })

  if (req.method === 'OPTIONS') return new Response('ok', { headers: corsHeaders })

  try {
    // Validate request method
    if (req.method !== 'POST') {
      return new Response('Method not allowed', { status: 405, headers: corsHeaders })
    }

    // Validate auth
    const authHeader = req.headers.get('Authorization')
    if (!authHeader) {
      return new Response(JSON.stringify({ error: 'Missing authorization' }), {
        status: 401, headers: { ...corsHeaders, 'Content-Type': 'application/json' }
      })
    }

    // Parse body safely
    let body: Record<string, unknown>
    try {
      body = await req.json()
    } catch {
      return new Response(JSON.stringify({ error: 'Invalid JSON body' }), {
        status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/json' }
      })
    }

    // Your business logic
    const result = await processRequest(body)

    return new Response(JSON.stringify({ data: result }), {
      status: 200, headers: { ...corsHeaders, 'Content-Type': 'application/json' }
    })

  } catch (error) {
    // Log for debugging (visible in Dashboard → Edge Functions → Logs)
    console.error('Function error:', error)

    // Return structured error — never expose stack traces in production
    return new Response(
      JSON.stringify({ error: 'Internal server error', code: error.code ?? 'UNKNOWN' }),
      { status: 500, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
    )
  }
})
```

### Idempotency — handle webhook retries safely
```typescript
// Webhooks are retried on failure — check for duplicate processing
const eventId = req.headers.get('x-webhook-id') ?? req.headers.get('stripe-signature')

const { data: existing } = await adminSupabase
  .from('processed_events')
  .select('id')
  .eq('event_id', eventId)
  .single()

if (existing) {
  // Already processed — return 200 so webhook stops retrying
  return new Response(JSON.stringify({ ok: true, duplicate: true }), { status: 200 })
}

// Process the event...
await adminSupabase.from('processed_events').insert({ event_id: eventId })
```

