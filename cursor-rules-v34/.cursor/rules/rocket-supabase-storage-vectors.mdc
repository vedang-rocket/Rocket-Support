## Querying Vector Buckets (Similarity Search)

```typescript
// lib/vector-search.ts
import { generateEmbedding } from '@/lib/embeddings'

export async function searchVectors(query: string, options: {
  topK?: number
  metadataFilter?: Record<string, unknown>
  returnMetadata?: boolean
} = {}) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) throw new Error('Unauthorized')

  // Generate embedding for the search query
  const queryEmbedding = await generateEmbedding(query)

  const { data, error } = await supabase.storage
    .vectors
    .from(BUCKET)
    .index(INDEX)
    .queryVectors({
      queryVector: { float32: queryEmbedding },
      topK: options.topK ?? 5,
      returnMetadata: options.returnMetadata ?? true,
      // Optional: filter by metadata before similarity search
      filter: options.metadataFilter,
    })

  if (error) throw new Error(`Vector search failed: ${error.message}`)

  return data.matches.map(match => ({
    key: match.key,
    score: match.score,      // similarity score (0–1 for cosine)
    metadata: match.metadata,
  }))
}

// Usage in an API route
// app/api/search/route.ts
export async function POST(request: Request) {
  const { query, filters } = await request.json()

  const results = await searchVectors(query, {
    topK: 10,
    metadataFilter: filters,   // e.g. { user_id: user.id, category: 'docs' }
  })

  return Response.json({ results })
}
```

