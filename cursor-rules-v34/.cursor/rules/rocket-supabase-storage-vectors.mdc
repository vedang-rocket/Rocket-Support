## Hybrid Architecture Implementation

```typescript
// lib/hybrid-search.ts — search both pgvector and Vector Buckets

export async function hybridSearch(query: string, userId: string) {
  const queryEmbedding = await generateEmbedding(query)

  // Search 1: pgvector — recent/hot docs with low latency
  const { data: pgResults } = await supabase.rpc('match_documents', {
    query_embedding: queryEmbedding,
    match_threshold: 0.78,
    match_count: 3,
    filter_user_id: userId,
  })

  // Search 2: Vector Buckets — full archive
  const { data: bucketMatches } = await supabase.storage
    .vectors.from('embeddings').index('documents-index')
    .queryVectors({
      queryVector: { float32: queryEmbedding },
      topK: 7,
      filter: { user_id: { $eq: userId } },
      returnMetadata: true,
    })

  // Merge and deduplicate results, rank by score
  const allResults = [
    ...(pgResults ?? []).map(r => ({ ...r, source: 'hot' })),
    ...(bucketMatches?.matches ?? []).map(m => ({
      id: m.key, content: m.metadata?.content, similarity: m.score, source: 'archive'
    })),
  ]
  .filter((v, i, a) => a.findIndex(t => t.id === v.id) === i) // deduplicate
  .sort((a, b) => b.similarity - a.similarity)
  .slice(0, 5)

  return allResults
}
```
