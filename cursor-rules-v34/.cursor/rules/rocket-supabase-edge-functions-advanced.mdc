# Supabase Edge Functions — Advanced Features Reference

---

## Background Tasks — EdgeRuntime.waitUntil()

**GA: December 2024**

Respond to the user immediately, then continue processing in the background.
The single most important pattern for AI apps — eliminates waiting for OpenAI calls.

### Basic pattern
```typescript
Deno.serve(async (req: Request) => {
  const corsHeaders = { 'Access-Control-Allow-Origin': '*', 'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type' }
  if (req.method === 'OPTIONS') return new Response('ok', { headers: corsHeaders })

  const { documentId, content } = await req.json()

  // ✅ Register background work BEFORE sending response
  // This continues running after the response is sent
  EdgeRuntime.waitUntil(
    processInBackground(documentId, content)
  )

  // ✅ Respond immediately — user doesn't wait
  return new Response(
    JSON.stringify({ ok: true, message: 'Processing started' }),
    { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
  )
})

async function processInBackground(documentId: string, content: string) {
  try {
    const supabase = createClient(
      Deno.env.get('SUPABASE_URL')!,
      Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!  // service role — no user context
    )

    // Generate embedding (would exceed CPU limit if done synchronously)
    const embedding = await generateEmbedding(content)

    // Store in database
    await supabase
      .from('documents')
      .update({ embedding, processed: true, processed_at: new Date().toISOString() })
      .eq('id', documentId)

    console.log(`Background: document ${documentId} embedded successfully`)
  } catch (error) {
    console.error(`Background: failed for ${documentId}:`, error)
    // Consider updating a status field so UI can show the error
  }
}
```

### Background task limits
```
Free tier:  150 seconds after response sent
Pro tier:   400 seconds after response sent

Multiple waitUntil() calls are allowed — they all run in parallel
Background tasks share the same 150MB memory budget
```

### Save state before shutdown (beforeunload)
```typescript
// Fires when Edge Runtime is shutting down — use to save progress
addEventListener('beforeunload', async (ev) => {
  console.log('Edge Runtime shutting down, reason:', ev.detail?.reason)
  // Save checkpoint to DB so work can resume
  await supabase.from('job_checkpoints').upsert({
    job_id: currentJobId,
    progress: currentProgress,
    updated_at: new Date().toISOString(),
  })
})
```

### Job queue pattern (pgmq + Edge Function)
```typescript
// Edge Function: process-queue/index.ts
// Called by pg_cron every 30 seconds via pg_net

Deno.serve(async (req: Request) => {
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  )

  // Read up to 10 messages from pgmq queue
  const { data: messages } = await supabase.rpc('pgmq_read', {
    queue_name: 'embeddings_queue',
    vt: 30,    // visibility timeout — message hidden from other workers for 30s
    qty: 10,
  })

  if (!messages?.length) {
    return new Response(JSON.stringify({ processed: 0 }))
  }

  // Process each message in background (don't block response)
  EdgeRuntime.waitUntil(
    Promise.all(messages.map(async (msg: any) => {
      try {
        const { document_id, content } = msg.message
        const embedding = await generateEmbedding(content)
        await supabase.from('documents')
          .update({ embedding })
          .eq('id', document_id)
        // Delete from queue — successfully processed
        await supabase.rpc('pgmq_delete', { queue_name: 'embeddings_queue', msg_id: msg.msg_id })
      } catch (err) {
        console.error('Queue processing error:', err)
        // Message becomes visible again after vt expires — will be retried
      }
    }))
  )

  return new Response(JSON.stringify({ processing: messages.length }))
})
```

