## WebSockets in Edge Functions

**GA: December 2024**

Edge Functions can act as WebSocket servers — bi-directional persistent connections.
Primary use case: OpenAI Realtime API relay for voice/audio streaming.

### WebSocket server basics
```typescript
// supabase/functions/ws-server/index.ts
Deno.serve(async (req: Request) => {
  // Check if client is requesting a WebSocket upgrade
  const upgrade = req.headers.get('upgrade') ?? ''
  if (upgrade.toLowerCase() !== 'websocket') {
    return new Response('Expected WebSocket upgrade', { status: 426 })
  }

  // Upgrade the connection
  const { socket, response } = Deno.upgradeWebSocket(req)

  socket.onopen = () => {
    console.log('Client connected')
    socket.send(JSON.stringify({ type: 'connected', timestamp: Date.now() }))
  }

  socket.onmessage = async (event) => {
    const message = JSON.parse(event.data)
    console.log('Received:', message)

    // Process and respond
    const result = await processMessage(message)
    socket.send(JSON.stringify(result))
  }

  socket.onerror = (error) => console.error('WebSocket error:', error)
  socket.onclose = () => console.log('Client disconnected')

  return response
})
```

### OpenAI Realtime API relay — voice/audio streaming
```typescript
// supabase/functions/realtime-relay/index.ts
// Relays between browser client and OpenAI Realtime API
// Required because: browser can't call OpenAI directly (exposes key), needs CORS relay

Deno.serve(async (req: Request) => {
  if (req.headers.get('upgrade')?.toLowerCase() !== 'websocket') {
    return new Response('WebSocket required', { status: 426 })
  }

  // Auth — WebSocket clients cannot send custom headers
  // Use query param for token (less ideal but necessary)
  const url = new URL(req.url)
  const token = url.searchParams.get('token')

  if (!token) {
    return new Response('Unauthorized', { status: 401 })
  }

  // Validate token
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_ANON_KEY')!,
  )
  const { data: { user }, error } = await supabase.auth.getUser(token)
  if (error || !user) return new Response('Unauthorized', { status: 401 })

  // Upgrade client connection
  const { socket: clientSocket, response } = Deno.upgradeWebSocket(req)

  // Connect to OpenAI Realtime API
  const openaiWs = new WebSocket(
    'wss://api.openai.com/v1/realtime?model=gpt-4o-realtime-preview',
    ['realtime', `openai-insecure-api-key.${Deno.env.get('OPENAI_API_KEY')}`, 'openai-beta.realtime-v1']
  )

  // Relay: client → OpenAI
  clientSocket.onmessage = (event) => {
    if (openaiWs.readyState === WebSocket.OPEN) {
      openaiWs.send(event.data)
    }
  }

  // Relay: OpenAI → client
  openaiWs.onmessage = (event) => {
    if (clientSocket.readyState === WebSocket.OPEN) {
      clientSocket.send(event.data)
    }
  }

  clientSocket.onclose = () => openaiWs.close()
  openaiWs.onclose = () => clientSocket.close()

  return response
})
```

### Client-side WebSocket connection (Next.js)
```typescript
// 'use client' component
const connectVoice = async () => {
  const { data: { session } } = await supabase.auth.getSession()

  // Pass token as query param — WebSockets cannot send custom headers
  const wsUrl = `${process.env.NEXT_PUBLIC_SUPABASE_URL!.replace('https', 'wss')}/functions/v1/realtime-relay?token=${session!.access_token}`

  const ws = new WebSocket(wsUrl)

  ws.onopen = () => console.log('Connected to realtime relay')
  ws.onmessage = (event) => handleOpenAIMessage(JSON.parse(event.data))
  ws.onerror = (err) => console.error('WebSocket error:', err)
}
```

### Local dev config for WebSockets
```toml
# supabase/config.toml — required for WebSocket local development
[edge_runtime]
policy = "per_worker"  # keeps workers alive for persistent WebSocket connections
# Default "oneshot" policy kills workers after each request — breaks WebSockets
```

