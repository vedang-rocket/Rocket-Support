## Ephemeral /tmp Storage

Edge Functions can write to `/tmp` during execution.
Files are cleared between invocations — NOT persistent storage.

Use for: processing large files without loading into memory, intermediate steps.

```typescript
import { writeFile, readFile, unlink } from 'node:fs/promises'
import { join } from 'node:path'
import { tmpdir } from 'node:os'

Deno.serve(async (req: Request) => {
  // Download a large file from Storage to /tmp (avoids loading 50MB into memory)
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  )

  const { data: fileData } = await supabase.storage
    .from('uploads')
    .download('large-document.pdf')

  // Write to /tmp for processing
  const tmpPath = join(tmpdir(), `doc-${Date.now()}.pdf`)
  await writeFile(tmpPath, new Uint8Array(await fileData!.arrayBuffer()))

  // Process the file (e.g., extract text, resize image, parse CSV)
  const result = await processFile(tmpPath)

  // Clean up (good practice — /tmp has limited space)
  await unlink(tmpPath)

  return new Response(JSON.stringify({ result }))
})
```

