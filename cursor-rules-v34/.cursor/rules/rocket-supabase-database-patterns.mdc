## Arrays

```sql
-- Array columns
CREATE TABLE products (
  tags        TEXT[],
  sizes       TEXT[] DEFAULT ARRAY['S', 'M', 'L'],
  rating_ids  INTEGER[]
);

-- Array operators
SELECT * FROM products WHERE 'nextjs' = ANY(tags);        -- contains value
SELECT * FROM products WHERE tags @> ARRAY['nextjs'];     -- contains all
SELECT * FROM products WHERE tags && ARRAY['react','vue'];-- overlaps (any match)

-- Append to array
UPDATE products SET tags = array_append(tags, 'new-tag') WHERE id = $1;
```

```typescript
// supabase-js array queries
const { data } = await supabase
  .from('products')
  .select()
  .contains('tags', ['nextjs'])          // tags contains 'nextjs'
  .overlaps('sizes', ['M', 'L'])         // sizes has M or L
```

