## JSONB — Unstructured Data

```sql
-- Always use JSONB not JSON (JSONB is indexed, stored binary, faster)
CREATE TABLE events (
  metadata JSONB DEFAULT '{}'
);

-- Operators
-- -> returns JSONB   ->> returns TEXT
SELECT metadata -> 'address' -> 'city'    FROM events;  -- nested JSONB
SELECT metadata ->> 'email'               FROM events;  -- as text (for WHERE)
SELECT metadata #>> '{address,city}'      FROM events;  -- path as text

-- Query by nested field
SELECT * FROM events WHERE metadata ->> 'email' = 'user@example.com';
SELECT * FROM events WHERE (metadata -> 'price')::INTEGER > 100;

-- GIN index for fast JSONB queries
CREATE INDEX events_metadata_idx ON events USING gin(metadata);
-- Or index a specific path:
CREATE INDEX events_email_idx ON events ((metadata ->> 'email'));
```

```typescript
// Query JSONB from supabase-js
const { data } = await supabase
  .from('events')
  .select()
  .eq('metadata->>email', 'user@example.com')     // ->> operator in filter
  .filter('metadata->>price', 'gt', '100')         // cast to text for comparison
```

