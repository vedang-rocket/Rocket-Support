## Database Functions

```sql
-- SECURITY INVOKER (default, recommended) — runs as the calling user, RLS applies
-- SECURITY DEFINER — runs as function owner (postgres), bypasses RLS — use carefully

-- Standard function — called via supabase.rpc()
CREATE OR REPLACE FUNCTION get_user_stats(p_user_id UUID)
RETURNS TABLE(total_orders INT, total_spent BIGINT)
LANGUAGE sql STABLE SECURITY INVOKER AS $$
  SELECT
    COUNT(*)::INT,
    COALESCE(SUM(amount), 0)
  FROM orders
  WHERE user_id = p_user_id AND status = 'completed' AND deleted_at IS NULL;
$$;
```

```typescript
// Call from Next.js
const { data, error } = await supabase.rpc('get_user_stats', { p_user_id: userId })
// data = { total_orders: 5, total_spent: 45000 }
```

```sql
-- SECURITY DEFINER function (use only when you NEED to bypass RLS)
-- ALWAYS set search_path to prevent search_path injection attacks
CREATE OR REPLACE FUNCTION admin_get_all_users()
RETURNS TABLE(id UUID, email TEXT)
LANGUAGE sql STABLE SECURITY DEFINER
SET search_path = public, auth AS $$
  SELECT id, email FROM auth.users;
$$;

-- Grant only to service_role or specific role
REVOKE EXECUTE ON FUNCTION admin_get_all_users() FROM PUBLIC, authenticated, anon;
GRANT EXECUTE ON FUNCTION admin_get_all_users() TO service_role;
```
