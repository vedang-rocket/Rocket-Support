## ⚡ NEXT.JS ERRORS


### `Error: Route param 'id' should be awaited before using its properties`
**Cause**: Next.js 15 made dynamic route params async
```typescript
// ❌ BROKEN (Next.js 14 syntax)
export default function Page({ params }: { params: { id: string } }) {
  const id = params.id
}

// ✅ FIX (Next.js 15)
export default async function Page({ params }: { params: Promise<{ id: string }> }) {
  const { id } = await params
}
```

---

### `Error: useSearchParams() should be wrapped in a suspense boundary`
**File**: Any page using `useSearchParams()`
**Cause**: Next.js 14+ requires `useSearchParams` inside `<Suspense>`
```typescript
// ❌ BROKEN
'use client'
import { useSearchParams } from 'next/navigation'
export default function Page() {
  const params = useSearchParams() // crashes
}

// ✅ FIX — wrap in Suspense
import { Suspense } from 'react'
function SearchComponent() {
  const params = useSearchParams()
  return <div>{params.get('q')}</div>
}
export default function Page() {
  return <Suspense fallback={<div>Loading...</div>}><SearchComponent /></Suspense>
}
```

