## Option B — Drizzle ORM (recommended for type-heavy projects)

### Install
```bash
npm install drizzle-orm postgres
npm install -D drizzle-kit
```

### Connection (port 6543 — required for Netlify serverless)
```typescript
// lib/db.ts
import { drizzle } from 'drizzle-orm/postgres-js'
import postgres from 'postgres'
import * as schema from './schema'

const client = postgres(process.env.DATABASE_URL!, {
  prepare: false,   // REQUIRED — Supavisor transaction mode does not support prepared statements
  max: 1,           // REQUIRED for serverless — prevents connection pool overflow
})

export const db = drizzle(client, { schema })
```

### Schema definition
```typescript
// lib/schema.ts
import { pgTable, uuid, text, integer, timestamp, pgEnum } from 'drizzle-orm/pg-core'

export const orderStatusEnum = pgEnum('order_status', ['pending', 'processing', 'completed', 'cancelled'])

export const profiles = pgTable('profiles', {
  id: uuid('id').primaryKey(),
  fullName: text('full_name'),
  avatarUrl: text('avatar_url'),
  createdAt: timestamp('created_at', { withTimezone: true }).defaultNow(),
})

export const orders = pgTable('orders', {
  id: uuid('id').primaryKey().defaultRandom(),
  userId: uuid('user_id').notNull().references(() => profiles.id, { onDelete: 'cascade' }),
  status: orderStatusEnum('status').default('pending'),
  amountCents: integer('amount_cents').notNull(),
  createdAt: timestamp('created_at', { withTimezone: true }).defaultNow(),
})
```

### drizzle.config.ts
```typescript
import type { Config } from 'drizzle-kit'

export default {
  schema: './lib/schema.ts',
  out: './supabase/migrations',
  dialect: 'postgresql',
  dbCredentials: {
    url: process.env.DIRECT_URL!,  // Use DIRECT_URL (port 5432) for migrations
  },
} satisfies Config
```

```bash
# Generate migration files
npx drizzle-kit generate

# Push to database (development)
npx drizzle-kit push

# Run migrations (production — applies SQL files)
npx drizzle-kit migrate
```

### Querying with Drizzle
```typescript
import { db } from '@/lib/db'
import { orders, profiles } from '@/lib/schema'
import { eq, desc, and } from 'drizzle-orm'

// Server-side only — Drizzle uses direct DB connection, bypasses supabase-js
// RLS still applies IF you set role to 'authenticated' — see note below

// Select with join
const result = await db
  .select({
    orderId: orders.id,
    status: orders.status,
    userName: profiles.fullName,
  })
  .from(orders)
  .innerJoin(profiles, eq(orders.userId, profiles.id))
  .where(and(eq(orders.status, 'pending')))
  .orderBy(desc(orders.createdAt))
  .limit(20)

// Insert
const [newOrder] = await db.insert(orders).values({
  userId: user.id,
  amountCents: 4999,
  status: 'pending',
}).returning()
```

### RLS with Drizzle — set the role
```typescript
// Drizzle uses the postgres/service_role by default — bypasses RLS
// To enforce RLS, run queries within a transaction that sets the user role:
await db.execute(sql`SET LOCAL role = authenticated`)
await db.execute(sql`SET LOCAL request.jwt.claims = '{"sub": "${userId}"}'`)
// Then run your query — RLS will apply
```

