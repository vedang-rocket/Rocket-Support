## B2B "Sign in with [Your App]" Pattern

```typescript
// Another app's sign-in button
const initiateOAuth = () => {
  const params = new URLSearchParams({
    response_type: 'code',
    client_id: 'REGISTERED_CLIENT_ID',
    redirect_uri: 'https://other-app.com/auth/callback',
    scope: 'openid profile email',
    code_challenge: generateCodeChallenge(),      // PKCE
    code_challenge_method: 'S256',
    state: generateRandomState(),
  })

  window.location.href =
    `https://[PROJECT_REF].supabase.co/auth/v1/authorize?${params}`
}

// Other app's callback — exchange code for token
const exchangeCode = async (code: string) => {
  const response = await fetch(
    `https://[PROJECT_REF].supabase.co/auth/v1/token`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        grant_type: 'authorization_code',
        code,
        redirect_uri: 'https://other-app.com/auth/callback',
        code_verifier: storedCodeVerifier,
        client_id: 'REGISTERED_CLIENT_ID',
        client_secret: 'CLIENT_SECRET',
      }),
    }
  )
  const { access_token, refresh_token } = await response.json()
  // Now has user access token — can call your Supabase API with RLS
}
```

