## High-Frequency Updates — Throttling Pattern

Cursor tracking, live document editing, and collaborative whiteboards can
easily exceed 100 events/sec. Always throttle.

```typescript
// ❌ WRONG — no throttle (cursor position on every mousemove)
document.addEventListener('mousemove', (e) => {
  channel.send({ type: 'broadcast', event: 'cursor', payload: { x: e.clientX, y: e.clientY } })
  // At 60fps this is 60 events/sec per user — hits free tier limit with 2 users
})

// ✅ CORRECT — throttle with eventsPerSecond param
const channel = supabase.channel('room:abc', {
  config: {
    broadcast: {
      self: false,        // don't receive your own broadcasts
      ack: false,         // don't wait for server ack (faster)
    },
  },
})

// Client-side rate limit (10 per second per client)
let lastSent = 0
document.addEventListener('mousemove', (e) => {
  const now = Date.now()
  if (now - lastSent < 100) return  // max 10/sec
  lastSent = now
  channel.send({ type: 'broadcast', event: 'cursor', payload: { x: e.clientX, y: e.clientY } })
})

// ✅ CORRECT — throttle presence updates (don't update on every keystroke)
const debouncedTrack = debounce((status: string) => {
  channel.track({ userId: user.id, status, lastSeen: new Date().toISOString() })
}, 500)  // max 2 presence updates per second
```

