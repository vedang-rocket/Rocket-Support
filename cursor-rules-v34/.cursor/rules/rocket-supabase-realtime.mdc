## realtime.broadcast_changes — DB Trigger Pattern

Lower overhead than Postgres Changes replication — uses a trigger to broadcast.
Recommended for high-write tables where Postgres Changes creates WAL pressure.

```sql
-- Create a trigger that broadcasts changes to a specific channel
-- Instead of: subscribing to postgres_changes (uses replication slot)
-- Use: realtime.broadcast_changes() in a trigger (much lighter)

CREATE OR REPLACE FUNCTION broadcast_order_change()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  PERFORM realtime.broadcast_changes(
    'orders:' || NEW.user_id::TEXT,  -- channel topic (matches client subscription)
    TG_OP,                            -- 'INSERT', 'UPDATE', or 'DELETE'
    TG_OP,                            -- event name sent to clients
    TG_TABLE_NAME,                    -- table name
    TG_TABLE_SCHEMA,                  -- schema name
    NEW,                              -- new record (null for DELETE)
    OLD                               -- old record (null for INSERT)
  );
  RETURN COALESCE(NEW, OLD);
END;
$$;

CREATE TRIGGER on_order_change
  AFTER INSERT OR UPDATE OR DELETE ON orders
  FOR EACH ROW EXECUTE FUNCTION broadcast_order_change();
```

```typescript
// Client subscribes to the broadcast channel (not postgres_changes)
const channel = supabase.channel(`orders:${user.id}`, { config: { private: true } })

channel
  .on('broadcast', { event: 'UPDATE' }, (payload) => {
    // payload.payload.record = new record
    // payload.payload.old_record = old record
    updateOrder(payload.payload.record)
  })
  .on('broadcast', { event: 'INSERT' }, (payload) => {
    addOrder(payload.payload.record)
  })
  .subscribe()
```

