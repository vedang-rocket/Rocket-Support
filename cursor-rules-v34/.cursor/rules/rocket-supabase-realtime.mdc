## Server-Side Broadcast (HTTP API)

Send to live WebSocket clients FROM a server, API route, or Edge Function.
No WebSocket connection needed on the server side.

```typescript
// From a Next.js API route or Edge Function
// Notify all users in a room when an order status changes

// app/api/orders/[id]/route.ts
export async function PATCH(request: Request, { params }: { params: { id: string } }) {
  const supabase = await createClient()  // server client
  const { status } = await request.json()

  // Update the order
  const { data: order, error } = await supabase
    .from('orders')
    .update({ status })
    .eq('id', params.id)
    .select('*, user_id')
    .single()

  if (error) return Response.json({ error: error.message }, { status: 500 })

  // Notify the user's realtime channel via HTTP (no WebSocket connection needed)
  const broadcastUrl = `${process.env.NEXT_PUBLIC_SUPABASE_URL}/realtime/v1/api/broadcast`

  await fetch(broadcastUrl, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${process.env.SUPABASE_SERVICE_ROLE_KEY}`,
      'apikey': process.env.SUPABASE_SERVICE_ROLE_KEY!,
    },
    body: JSON.stringify({
      messages: [
        {
          topic: `user:${order.user_id}`,  // channel name the client subscribed to
          event: 'order_updated',
          payload: { orderId: order.id, status: order.status },
        }
      ]
    }),
  })

  return Response.json({ ok: true })
}
```

```typescript
// Client: receive the server-sent broadcast
const channel = supabase.channel(`user:${user.id}`, { config: { private: true } })

channel
  .on('broadcast', { event: 'order_updated' }, (payload) => {
    // Update order status in UI
    setOrderStatus(payload.payload.status)
    toast.success(`Order ${payload.payload.status}!`)
  })
  .subscribe()
```

