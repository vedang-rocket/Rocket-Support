## Silent Disconnection & Reconnection

Mobile browsers and OS background mode kill WebSocket connections silently.
Without reconnection handling, real-time stops working and users never notice.

```typescript
// Robust realtime hook with reconnection
function useRealtimeChannel(channelName: string, onMessage: (payload: any) => void) {
  const supabase = createClient()

  useEffect(() => {
    let channel: ReturnType<typeof supabase.channel>
    let reconnectTimer: ReturnType<typeof setTimeout>
    let mounted = true

    const connect = () => {
      channel = supabase.channel(channelName, { config: { private: true } })

      channel
        .on('broadcast', { event: 'message' }, onMessage)
        .subscribe((status) => {
          if (!mounted) return

          if (status === 'TIMED_OUT' || status === 'CHANNEL_ERROR') {
            // Clean up and retry after 3 seconds
            supabase.removeChannel(channel)
            reconnectTimer = setTimeout(connect, 3000)
          }
        })
    }

    connect()

    // Reconnect on browser visibility restore (tab becomes active again)
    const handleVisibilityChange = () => {
      if (document.visibilityState === 'visible') {
        supabase.removeChannel(channel)
        clearTimeout(reconnectTimer)
        connect()
      }
    }
    document.addEventListener('visibilitychange', handleVisibilityChange)

    return () => {
      mounted = false
      clearTimeout(reconnectTimer)
      supabase.removeChannel(channel)
      document.removeEventListener('visibilitychange', handleVisibilityChange)
    }
  }, [channelName])
}
```

