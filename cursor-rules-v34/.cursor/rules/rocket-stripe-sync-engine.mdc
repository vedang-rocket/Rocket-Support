## Joining Stripe Data With Your Tables

```sql
-- Your profiles table must store stripe_customer_id for the join to work
-- Add if not already present:
ALTER TABLE public.profiles ADD COLUMN IF NOT EXISTS stripe_customer_id TEXT;
CREATE INDEX IF NOT EXISTS profiles_stripe_cid ON profiles(stripe_customer_id);

-- Users with active subscriptions
SELECT
  p.id,
  p.email,
  s.status AS subscription_status,
  s.current_period_end,
  s.cancel_at_period_end
FROM public.profiles p
JOIN stripe_sync.customers c ON c.id = p.stripe_customer_id
JOIN stripe_sync.subscriptions s ON s.customer_id = c.id
WHERE s.status = 'active';

-- Revenue by plan (last 30 days)
SELECT
  pr.name AS plan_name,
  COUNT(s.id) AS active_subscriptions,
  SUM(p.unit_amount / 100.0) AS mrr_usd
FROM stripe_sync.subscriptions s
JOIN stripe_sync.subscription_items si ON si.subscription_id = s.id
JOIN stripe_sync.prices p ON p.id = si.price_id
JOIN stripe_sync.products pr ON pr.id = p.product_id
WHERE s.status = 'active'
GROUP BY pr.name;

-- Users with past_due or unpaid subscriptions (need dunning)
SELECT
  prof.email,
  s.status,
  s.current_period_end AS due_date
FROM stripe_sync.subscriptions s
JOIN stripe_sync.customers c ON c.id = s.customer_id
JOIN public.profiles prof ON prof.stripe_customer_id = c.id
WHERE s.status IN ('past_due', 'unpaid')
ORDER BY s.current_period_end;
```

