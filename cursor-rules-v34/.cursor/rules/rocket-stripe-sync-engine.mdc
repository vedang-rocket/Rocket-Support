## Access From Server-Side Next.js

```typescript
// lib/supabase/admin.ts — use admin client for stripe_sync schema
import { createAdminClient } from '@/lib/supabase/admin'

export async function getUserSubscriptionStatus(stripeCustomerId: string) {
  const supabase = createAdminClient()

  const { data, error } = await supabase
    .schema('stripe_sync')
    .from('subscriptions')
    .select('status, current_period_end, cancel_at_period_end')
    .eq('customer_id', stripeCustomerId)
    .eq('status', 'active')
    .maybeSingle()

  return { subscription: data, error }
}

// OR via a SECURITY DEFINER SQL function (cleaner for RLS-scoped access)
```

```sql
-- Create a function users can call via supabase.rpc() to get their own subscription
CREATE OR REPLACE FUNCTION get_my_subscription()
RETURNS TABLE(status TEXT, current_period_end TIMESTAMPTZ, cancel_at_period_end BOOLEAN)
LANGUAGE sql STABLE SECURITY DEFINER
SET search_path = public, stripe_sync AS $$
  SELECT s.status, s.current_period_end, s.cancel_at_period_end
  FROM stripe_sync.subscriptions s
  JOIN stripe_sync.customers c ON c.id = s.customer_id
  JOIN public.profiles p ON p.stripe_customer_id = c.id
  WHERE p.id = auth.uid()
    AND s.status IN ('active', 'trialing', 'past_due')
  LIMIT 1;
$$;
```

```typescript
// Client call
const { data } = await supabase.rpc('get_my_subscription')
```

