## Custom Postgres Roles (RBAC)

For projects where users have different roles (admin, moderator, member), use custom Postgres roles controlled via JWT claims.

### Step 1 — Create a roles table
```sql
CREATE TYPE app_role AS ENUM ('admin', 'moderator', 'member');

CREATE TABLE user_roles (
  id      UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  role    app_role NOT NULL DEFAULT 'member',
  UNIQUE(user_id)
);

ALTER TABLE user_roles ENABLE ROW LEVEL SECURITY;
-- Only admins can modify roles — regular users can read their own
CREATE POLICY "users_read_own_role" ON user_roles FOR SELECT USING (auth.uid() = user_id);
```

### Step 2 — Auth hook adds role to JWT
```sql
-- Custom Access Token hook (see rocket-supabase-auth-advanced.mdc)
CREATE OR REPLACE FUNCTION public.custom_access_token_hook(event JSONB)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER
SET search_path = public AS $$
DECLARE
  claims JSONB;
  user_role app_role;
BEGIN
  SELECT role INTO user_role FROM public.user_roles WHERE user_id = (event->>'user_id')::UUID;
  claims := event->'claims';
  claims := jsonb_set(claims, '{user_role}', to_jsonb(COALESCE(user_role::TEXT, 'member')));
  RETURN jsonb_set(event, '{claims}', claims);
END;
$$;

GRANT EXECUTE ON FUNCTION public.custom_access_token_hook TO supabase_auth_admin;
REVOKE EXECUTE ON FUNCTION public.custom_access_token_hook FROM authenticated, anon, public;
```

```
Connect hook: Authentication → Hooks → Custom Access Token → public.custom_access_token_hook
```

### Step 3 — Helper function to read role from JWT in RLS
```sql
CREATE OR REPLACE FUNCTION auth.user_role()
RETURNS TEXT LANGUAGE sql STABLE AS $$
  SELECT COALESCE(auth.jwt() ->> 'user_role', 'member');
$$;
```

### Step 4 — RLS policies that use the role
```sql
-- Admins can see all records; members see only their own
CREATE POLICY "role_based_access" ON orders FOR SELECT
USING (
  auth.user_role() = 'admin'
  OR auth.uid() = user_id
);

-- Only admins can delete
CREATE POLICY "admin_only_delete" ON orders FOR DELETE
USING (auth.user_role() = 'admin');
```

### Step 5 — Read role in Next.js
```typescript
// Server Component or API route
const { data: { user } } = await supabase.auth.getUser()
const userRole = user?.app_metadata?.user_role as 'admin' | 'moderator' | 'member'
// Note: app_metadata is in the JWT — read it from getUser() server-side
// Do NOT use user.user_metadata — that is user-writable
```

