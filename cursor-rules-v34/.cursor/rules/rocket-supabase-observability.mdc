## Cost Monitoring

```typescript
// Track OpenAI costs per request — log to analytics or a simple table
CREATE TABLE ai_usage (
  id         BIGINT GENERATED ALWAYS AS IDENTITY,
  user_id    UUID REFERENCES auth.users(id),
  model      TEXT,
  prompt_tokens INT,
  completion_tokens INT,
  estimated_cost_usd NUMERIC(10, 6),
  endpoint   TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE ai_usage ENABLE ROW LEVEL SECURITY;
-- Only service_role can insert (from server-side code)
-- Users can read their own usage
CREATE POLICY "read_own_usage" ON ai_usage FOR SELECT USING (auth.uid() = user_id);
```

```typescript
// lib/ai-tracker.ts
const COST_PER_1K: Record<string, { in: number; out: number }> = {
  'gpt-4o-mini':              { in: 0.00015, out: 0.0006 },
  'gpt-4o':                   { in: 0.005,   out: 0.015 },
  'text-embedding-3-small':   { in: 0.00002, out: 0 },
}

export async function trackAIUsage(supabase: any, params: {
  userId: string; model: string; promptTokens: number;
  completionTokens: number; endpoint: string
}) {
  const rates = COST_PER_1K[params.model] ?? { in: 0, out: 0 }
  const cost = (params.promptTokens / 1000 * rates.in) + (params.completionTokens / 1000 * rates.out)

  await supabase.from('ai_usage').insert({
    user_id: params.userId, model: params.model,
    prompt_tokens: params.promptTokens, completion_tokens: params.completionTokens,
    estimated_cost_usd: cost, endpoint: params.endpoint,
  })
}
```
