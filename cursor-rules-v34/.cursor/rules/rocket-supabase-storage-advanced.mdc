## Storage Ownership Pattern — The Correct RLS Approach

Store files at `{user_id}/{filename}` — this makes RLS policies use helper functions
instead of querying another table.

```typescript
// CORRECT: include user_id as the first path segment
const filePath = `${user.id}/avatar.jpg`          // private bucket
const filePath = `${user.id}/${Date.now()}.jpg`   // multiple files
const filePath = `${user.id}/posts/${postId}.jpg` // nested
```

```sql
-- storage.foldername(name) returns ARRAY of path segments split by '/'
-- name = 'abc-user-id/avatar.jpg'
-- storage.foldername(name) = ARRAY['abc-user-id', 'avatar.jpg']
-- storage.foldername(name)[1] = 'abc-user-id' (first segment = user_id)

-- Standard ownership policies using foldername()
CREATE POLICY "users_upload_own_files"
ON storage.objects FOR INSERT
WITH CHECK (
  bucket_id = 'uploads'
  AND auth.uid()::TEXT = (storage.foldername(name))[1]
);

CREATE POLICY "users_read_own_files"
ON storage.objects FOR SELECT
USING (
  bucket_id = 'uploads'
  AND auth.uid()::TEXT = (storage.foldername(name))[1]
);

CREATE POLICY "users_delete_own_files"
ON storage.objects FOR DELETE
USING (
  bucket_id = 'uploads'
  AND auth.uid()::TEXT = (storage.foldername(name))[1]
);

-- storage.filename(name) = just the filename without folder path
-- storage.foldername(name) = array of folder segments
-- Both are built-in Supabase storage helper functions
```

