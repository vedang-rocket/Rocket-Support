```typescript
// app/api/chat/route.ts — trace RAG calls
import { langfuse } from '@/lib/langfuse'
import { streamText } from 'ai'

export async function POST(request: Request) {
  const { messages, userId } = await request.json()
  const trace = langfuse.trace({ name: 'rag-chat', userId })

  // Track retrieval
  const retrievalSpan = trace.span({ name: 'vector-retrieval' })
  const context = await retrieveContext(supabase, messages.at(-1).content)
  retrievalSpan.end({ output: { chunksRetrieved: context?.length ?? 0 } })

  // Track generation
  const genSpan = trace.generation({
    name: 'openai-stream',
    model: 'gpt-4o-mini',
    input: messages,
  })

  const result = streamText({
    model: openai('gpt-4o-mini'),
    messages,
    onFinish: ({ usage }) => {
      genSpan.end({ usage: { input: usage.promptTokens, output: usage.completionTokens } })
      langfuse.flushAsync()   // flush before response ends
    },
  })

  return result.toDataStreamResponse()
}
```

