## RAG Evaluation — Did Your Answer Work?

```typescript
// lib/rag-eval.ts — simple faithfulness check
export async function evaluateRAGAnswer(params: {
  question: string
  context: string
  answer: string
  userId: string
}) {
  // Check if answer is grounded in the context (hallucination detection)
  const { object } = await generateObject({
    model: openai('gpt-4o-mini'),
    schema: z.object({
      faithful: z.boolean(),
      confidence: z.number().min(0).max(1),
      unsupported_claims: z.array(z.string()),
    }),
    prompt: `
Given this context: ${params.context}
And this answer: ${params.answer}
Is the answer faithful to the context? List any unsupported claims.
    `.trim(),
  })

  // Log evaluation result
  await supabase.from('rag_evaluations').insert({
    user_id: params.userId,
    question: params.question,
    faithful: object.faithful,
    confidence: object.confidence,
    unsupported_claims: object.unsupported_claims,
    created_at: new Date().toISOString(),
  })

  return object
}
```

