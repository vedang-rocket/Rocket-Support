## Structured Output — Zod Validation

```typescript
// app/api/extract/route.ts — extract structured data from unstructured text
import { generateObject } from 'ai'
import { openai } from '@ai-sdk/openai'
import { z } from 'zod'

const OrderSchema = z.object({
  items: z.array(z.object({
    product: z.string(),
    quantity: z.number().positive(),
    price: z.number().positive(),
  })),
  total: z.number().positive(),
  currency: z.enum(['USD', 'EUR', 'GBP']),
})

export async function POST(request: Request) {
  const { emailText } = await request.json()

  const { object: order } = await generateObject({
    model: openai('gpt-4o-mini'),
    schema: OrderSchema,
    prompt: `Extract the order details from this email: ${emailText}`,
  })

  // order is fully typed as { items: [...], total: number, currency: 'USD' | 'EUR' | 'GBP' }
  return Response.json({ order })
}
```

```typescript
// useObject hook — stream structured data to the client
'use client'
import { experimental_useObject as useObject } from 'ai/react'
import { z } from 'zod'

const ProfileSchema = z.object({
  name: z.string(),
  skills: z.array(z.string()),
  summary: z.string(),
})

export function ProfileExtractor() {
  const { object, submit, isLoading } = useObject({
    api: '/api/extract-profile',
    schema: ProfileSchema,
  })

  return (
    <div>
      <button onClick={() => submit({ resumeText: '...' })}>Extract Profile</button>
      {/* object streams in incrementally — partial values as they arrive */}
      {object?.name && <p>Name: {object.name}</p>}
      {object?.skills && <p>Skills: {object.skills.join(', ')}</p>}
    </div>
  )
}
```

