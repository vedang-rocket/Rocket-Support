## config.toml — Per-Environment Configuration

```toml
# supabase/config.toml
# Settings here apply to ALL environments unless overridden in [remotes.*]

[auth]
site_url = "http://localhost:3000"
additional_redirect_urls = ["https://localhost:3000"]
jwt_expiry = 3600
enable_signup = true

[auth.email]
enable_confirmations = false   # disabled for local dev

# Override for staging branch
[remotes.staging]
project_id = "your-staging-project-ref"

[remotes.staging.auth]
site_url = "https://staging.yourdomain.com"
enable_confirmations = true

# Override for production (set via CI, not config.toml for security)
# NEVER put production project_id in config.toml committed to git
```

