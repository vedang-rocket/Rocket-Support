## S3 FDW — Query Files in S3 as Tables

Use case: Import CSV/Parquet files from S3 directly into queries without downloading.

```sql
CREATE EXTENSION IF NOT EXISTS wrappers WITH SCHEMA extensions;

SELECT vault.create_secret('AKIAIOSFODNN7EXAMPLE', 's3_access_key');
SELECT vault.create_secret('wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY', 's3_secret_key');

CREATE SERVER s3_server
  FOREIGN DATA WRAPPER s3_wrapper
  OPTIONS (
    aws_access_key_id_id     '[access_key_vault_uuid]',
    aws_secret_access_key_id '[secret_key_vault_uuid]',
    aws_region               'us-east-1'
  );

CREATE SCHEMA IF NOT EXISTS s3_data;

-- Query a CSV file in S3 as a table
CREATE FOREIGN TABLE s3_data.monthly_exports (
  user_id    TEXT,
  event      TEXT,
  created_at TEXT
)
SERVER s3_server
OPTIONS (
  uri      's3://your-bucket/exports/2026-03.csv',
  format   'csv',
  has_header 'true'
);

-- Now query it like a regular table
SELECT event, COUNT(*) FROM s3_data.monthly_exports GROUP BY event;
```

