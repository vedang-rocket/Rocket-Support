## Firebase FDW — Migrate FROM Firebase to Supabase

Use case: Read Firestore data directly from Postgres during migration.
Query both databases simultaneously to validate data parity.

### Setup
```sql
-- Store Firebase service account credentials in Vault
SELECT vault.create_secret(
  '{"type":"service_account","project_id":"...","private_key":"..."}',
  'firebase_service_account',
  'Firebase service account JSON'
);

CREATE SERVER firebase_server
  FOREIGN DATA WRAPPER firebase_wrapper
  OPTIONS (
    sa_key_id '[VAULT_UUID]',
    project_id 'your-firebase-project-id'
  );

CREATE SCHEMA IF NOT EXISTS firebase;
REVOKE ALL ON SCHEMA firebase FROM PUBLIC, anon, authenticated;

-- Map a Firestore collection to a foreign table
CREATE FOREIGN TABLE firebase.users (
  name TEXT,           -- document path
  attrs JSONB          -- all document fields
)
SERVER firebase_server
OPTIONS (object 'users');   -- Firestore collection name
```

### Migration validation queries
```sql
-- Count comparison: Firebase vs Supabase
SELECT
  (SELECT COUNT(*) FROM firebase.users) AS firebase_count,
  (SELECT COUNT(*) FROM public.profiles) AS supabase_count;

-- Find Firebase users not yet migrated to Supabase
SELECT fb.attrs->>'email' AS email
FROM firebase.users fb
WHERE NOT EXISTS (
  SELECT 1 FROM public.profiles p
  WHERE p.email = fb.attrs->>'email'
);
```

