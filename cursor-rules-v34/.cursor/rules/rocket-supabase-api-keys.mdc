## createClient — Both Systems

```typescript
// lib/supabase/client.ts — browser ('use client')
import { createBrowserClient } from '@supabase/ssr'

export function createClient() {
  return createBrowserClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    // Works with BOTH key systems — supabase-js accepts either key format
    process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY   // new projects
    ?? process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,     // legacy projects
  )
}

// lib/supabase/server.ts — server-side (Server Components, API routes)
import { createServerClient } from '@supabase/ssr'
import { cookies } from 'next/headers'

export async function createClient() {
  const cookieStore = await cookies()
  return createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
    ?? process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    { cookies: { getAll: () => cookieStore.getAll(), setAll: (c) => c.forEach(({ name, value, options }) => cookieStore.set(name, value, options)) } }
  )
}

// lib/supabase/admin.ts — server-side admin (bypasses RLS)
import { createClient as createSupabaseClient } from '@supabase/supabase-js'

export function createAdminClient() {
  return createSupabaseClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.SUPABASE_SECRET_KEY         // new projects
    ?? process.env.SUPABASE_SERVICE_ROLE_KEY!,  // legacy projects
    { auth: { autoRefreshToken: false, persistSession: false } }
  )
}
```

