## Core Queue Operations

### Send a message
```typescript
// Server-side (API route or Edge Function)
const { data: msgId, error } = await supabase
  .schema('pgmq_public')
  .rpc('send', {
    queue_name: 'embeddings_queue',
    message: {                          // any JSON object
      document_id: documentId,
      user_id: user.id,
      content: text,
      priority: 'normal',
    },
  })
// Returns: message ID (bigint)

// Send with delay (message becomes visible after N seconds)
const { data: msgId } = await supabase
  .schema('pgmq_public')
  .rpc('send_with_delay', {
    queue_name: 'embeddings_queue',
    message: { document_id: documentId },
    delay_seconds: 30,                  // process 30 seconds from now
  })
```

### Read messages (with visibility timeout)
```typescript
// Read up to 10 messages — hides them for 60s (vt = visibility timeout)
// Other workers won't see these messages for 60 seconds
// If not deleted within 60s → becomes visible again (automatic retry)
const { data: messages } = await supabase
  .schema('pgmq_public')
  .rpc('read', {
    queue_name: 'embeddings_queue',
    vt: 60,                // visibility timeout in seconds
    qty: 10,               // max messages to read
  })

// messages = [{ msg_id, read_ct, enqueued_at, vt, message }, ...]
```

### Delete after successful processing
```typescript
// ALWAYS delete after processing — prevents re-delivery
const { error } = await supabase
  .schema('pgmq_public')
  .rpc('delete', {
    queue_name: 'embeddings_queue',
    msg_id: message.msg_id,
  })

// Or delete multiple at once
await supabase.schema('pgmq_public').rpc('delete_batch', {
  queue_name: 'embeddings_queue',
  msg_ids: messages.map(m => m.msg_id),
})
```

### Archive instead of delete (keep for audit)
```typescript
// Moves message to pgmq.a_[queue_name] archive table (not deleted)
await supabase.schema('pgmq_public').rpc('archive', {
  queue_name: 'embeddings_queue',
  msg_id: message.msg_id,
})
```

