## Edge Function Worker Pattern

```typescript
// supabase/functions/process-queue/index.ts
// Triggered by pg_cron every 10 seconds

Deno.serve(async (req: Request) => {
  const corsHeaders = { 'Access-Control-Allow-Origin': '*', 'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type' }
  if (req.method === 'OPTIONS') return new Response('ok', { headers: corsHeaders })

  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SECRET_KEY') ?? Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  )

  // Read batch of messages
  const { data: messages, error } = await supabase
    .schema('pgmq_public')
    .rpc('read', { queue_name: 'embeddings_queue', vt: 60, qty: 10 })

  if (error || !messages?.length) {
    return new Response(JSON.stringify({ processed: 0 }), { headers: corsHeaders })
  }

  // Process in background — respond immediately
  EdgeRuntime.waitUntil(
    Promise.all(messages.map(async (msg: any) => {
      try {
        const { document_id, content } = msg.message

        // Generate embedding
        const session = new Supabase.ai.Session('gte-small')
        const embedding = await session.run(content, { mean_pool: true, normalize: true })

        // Update document section
        await supabase
          .from('document_sections')
          .update({ embedding: Array.from(embedding) })
          .eq('id', document_id)

        // Delete message — successfully processed
        await supabase.schema('pgmq_public').rpc('delete', {
          queue_name: 'embeddings_queue',
          msg_id: msg.msg_id,
        })

        console.log(`Processed message ${msg.msg_id}`)
      } catch (err) {
        console.error(`Failed message ${msg.msg_id}:`, err)
        // Do NOT delete — message becomes visible again after vt expires → automatic retry
      }
    }))
  )

  return new Response(JSON.stringify({ processing: messages.length }), { headers: corsHeaders })
})
```

```sql
-- pg_cron: trigger the Edge Function worker every 10 seconds
SELECT cron.schedule(
  'process-embeddings-queue',
  '*/10 * * * * *',   -- every 10 seconds (sub-minute syntax)
  $$
  SELECT net.http_post(
    url     := current_setting('app.supabase_url') || '/functions/v1/process-queue',
    headers := jsonb_build_object(
      'Content-Type', 'application/json',
      'Authorization', 'Bearer ' || current_setting('app.service_role_key')
    ),
    body    := '{}'::JSONB
  )
  $$
);
```

