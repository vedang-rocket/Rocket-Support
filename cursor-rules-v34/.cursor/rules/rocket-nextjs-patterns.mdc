## Supabase Client in Server Actions

```typescript
// IMPORTANT: createClient() in Server Actions uses cookies() — same as Server Components
// You get the user's session automatically — no need to pass auth tokens

'use server'
import { createClient } from '@/lib/supabase/server'  // uses cookies() internally

export async function myAction() {
  const supabase = await createClient()
  // This client is authenticated as the current user
  // RLS applies automatically
  const { data } = await supabase.from('orders').select()
  // Returns only the current user's orders (if RLS is set up correctly)
}

// For admin actions that bypass RLS:
import { createAdminClient } from '@/lib/supabase/admin'

export async function adminAction() {
  // First verify the user is an admin
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  const role = user?.app_metadata?.user_role
  if (role !== 'admin') return { error: 'Forbidden' }

  // Then use admin client
  const adminSupabase = createAdminClient()
  const { data } = await adminSupabase.from('all_orders').select()
  return { data }
}
```

