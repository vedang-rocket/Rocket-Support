## Middleware Chaining Pattern

Handle auth + other concerns without nesting callbacks.

```typescript
// middleware.ts
import { createServerClient }            from '@supabase/ssr'
import { type NextRequest, NextResponse } from 'next/server'

type MiddlewareFn = (req: NextRequest, res: NextResponse) =>
  Promise<NextResponse | null>

// Compose: first function returning non-null response wins; null = continue chain
async function chain(
  req: NextRequest,
  handlers: MiddlewareFn[]
): Promise<NextResponse> {
  const base = NextResponse.next({ request: req })
  for (const fn of handlers) {
    const result = await fn(req, base)
    if (result) return result
  }
  return base
}

// ── individual middlewares ─────────────────────────────────────────────────

async function maintenanceMiddleware(req: NextRequest): Promise<NextResponse | null> {
  if (process.env.MAINTENANCE_MODE === 'true'
      && !req.nextUrl.pathname.startsWith('/maintenance')) {
    return NextResponse.redirect(new URL('/maintenance', req.url))
  }
  return null
}

async function authMiddleware(req: NextRequest, res: NextResponse): Promise<NextResponse | null> {
  // Refresh Supabase session on every request (required by @supabase/ssr)
  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
      ?? process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        getAll: ()  => req.cookies.getAll(),
        setAll: (c) => c.forEach(({ name, value, options }) =>
                        res.cookies.set(name, value, options)),
      },
    }
  )
  await supabase.auth.getUser()   // refreshes token in cookies

  const { data: { user } } = await supabase.auth.getUser()
  const protectedPaths = ['/dashboard', '/settings', '/account']
  const isProtected    = protectedPaths.some(p => req.nextUrl.pathname.startsWith(p))

  if (isProtected && !user) {
    const loginUrl = new URL('/login', req.url)
    loginUrl.searchParams.set('next', req.nextUrl.pathname)
    return NextResponse.redirect(loginUrl)
  }
  return null
}

// ── main export ────────────────────────────────────────────────────────────

export async function middleware(req: NextRequest) {
  return chain(req, [maintenanceMiddleware, authMiddleware])
}

export const config = {
  matcher: [
    '/((?!_next/static|_next/image|favicon\.ico|.*\.(?:svg|png|jpg|ico|css|js)$).*)',
  ],
}
```
