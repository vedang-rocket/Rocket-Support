## Next.js 15.2 — searchParams and params Are Now Promises

In Next.js 15.2 the `params` and `searchParams` props in page/layout components became
asynchronous. Accessing them synchronously causes a warning in 15.1 and a hard error in 15.2+.

```typescript
// ❌ WRONG — synchronous access (15.1 warning, 15.2 runtime error)
export default function SearchPage({
  searchParams,
}: { searchParams: { q: string; page: string } }) {
  const query = searchParams.q          // TypeError in 15.2
  const page  = Number(searchParams.page)
}

// ✅ CORRECT — await both params and searchParams
export default async function SearchPage({
  params,
  searchParams,
}: {
  params:       Promise<{ category: string }>
  searchParams: Promise<{ q?: string; page?: string; sort?: string }>
}) {
  const { category }    = await params
  const { q = '', page = '1', sort = 'created_at' } = await searchParams

  const supabase = await createClient()
  const { data } = await supabase
    .from('products')
    .select()
    .eq('category', category)
    .ilike('name', `%${q}%`)
    .order(sort)
    .range((Number(page) - 1) * 20, Number(page) * 20 - 1)

  return <ProductList products={data ?? []} />
}
```

```typescript
// Client components: use the useSearchParams() hook (unchanged — still sync)
'use client'
import { useSearchParams, useParams } from 'next/navigation'

export function SearchWidget() {
  const searchParams = useSearchParams()   // still sync in client components
  const params       = useParams()
  const q = searchParams.get('q') ?? ''
  return <input defaultValue={q} />
}
```

