## Cache Strategy — unstable_cache for Expensive Queries

```typescript
// lib/cached-data.ts
import { unstable_cache } from 'next/cache'
import { createClient } from '@/lib/supabase/server'

// Cache expensive queries — revalidate on tag
export const getProductCatalog = unstable_cache(
  async () => {
    const supabase = await createClient()
    const { data } = await supabase
      .from('products')
      .select('id, name, price, category')
      .eq('active', true)
      .order('name')
    return data ?? []
  },
  ['product-catalog'],           // cache key
  {
    tags: ['products'],          // invalidation tag
    revalidate: 3600,            // also revalidate after 1 hour regardless
  }
)

// Usage in Server Component (fast — cached)
export default async function CatalogPage() {
  const products = await getProductCatalog()
  return <ProductGrid products={products} />
}

// Invalidate when products change (in Server Action or API route)
import { revalidateTag } from 'next/cache'
revalidateTag('products')       // all getProductCatalog calls refetch
```

### What NEVER to cache (auth-dependent routes)
```typescript
// ❌ NEVER cache pages that read user-specific data
export const revalidate = 60         // breaks with Supabase auth
export const dynamic = 'force-static' // breaks with Supabase auth

// ✅ Always force dynamic for authenticated routes
export const dynamic = 'force-dynamic'
```

