## dynamicIO — Opt-In Async I/O (Next.js 15 Experimental)

```typescript
// next.config.ts
import type { NextConfig } from 'next'

const nextConfig: NextConfig = {
  experimental: {
    dynamicIO: true,   // uncached async calls make the route dynamic by default
  },
}
export default nextConfig
```

```typescript
// With dynamicIO enabled:
// Any page that calls supabase.from() WITHOUT unstable_cache becomes dynamic
// → good: no accidental caching of user-specific data
// → requires explicit opt-in to caching via unstable_cache

import { unstable_cache } from 'next/cache'
import { createAdminClient } from '@/lib/supabase/admin'

// Public catalog — EXPLICITLY cached
export const getPublicCatalog = unstable_cache(
  async () => {
    const s = createAdminClient()
    const { data } = await s.from('products').select().eq('active', true)
    return data ?? []
  },
  ['public-catalog'],
  { tags: ['products'], revalidate: 3600 }
)

// User dashboard — NOT wrapped → stays dynamic (correct behaviour)
export default async function DashboardPage() {
  const supabase = await createClient()            // user session
  const { data } = await supabase.from('orders').select()
  return <Orders data={data} />
}
```

