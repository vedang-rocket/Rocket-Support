# Next.js Modern Patterns — Server Actions, Caching & 15.2 Edge Cases

---

## Server Actions vs API Routes — When to Use Which

```
Server Actions ('use server'):
  ✅ Form submissions
  ✅ Mutations (create, update, delete)
  ✅ Actions triggered by user interaction
  ✅ When you need revalidatePath/revalidateTag after mutation
  ✅ Less boilerplate — no Request/Response wrapping

API Routes (app/api/*/route.ts):
  ✅ Webhook handlers (Stripe, GitHub) — need raw request body
  ✅ Endpoints called by external services
  ✅ File uploads
  ✅ Streaming responses (SSE, WebSockets)
  ✅ Third-party OAuth callbacks
  ❌ Don't use for simple mutations — Server Actions are better
```

---

## Server Actions — Complete Pattern

```typescript
// app/actions/orders.ts
'use server'
import { createClient } from '@/lib/supabase/server'
import { revalidatePath, revalidateTag } from 'next/cache'
import { redirect } from 'next/navigation'
import { z } from 'zod'

const CreateOrderSchema = z.object({
  items: z.array(z.object({ productId: z.string(), quantity: z.number().min(1) })),
})

export async function createOrder(formData: FormData) {
  // 1. Auth check (always first in Server Actions)
  const supabase = await createClient()
  const { data: { user }, error: authError } = await supabase.auth.getUser()
  if (authError || !user) redirect('/login')

  // 2. Validate input
  const items = JSON.parse(formData.get('items') as string)
  const parsed = CreateOrderSchema.safeParse({ items })
  if (!parsed.success) {
    return { error: parsed.error.flatten().fieldErrors }
  }

  // 3. Perform mutation
  const { data: order, error } = await supabase
    .from('orders')
    .insert({ user_id: user.id, status: 'pending' })
    .select()
    .single()

  if (error) return { error: { _form: [error.message] } }

  // 4. Invalidate cache — pages that show orders will refetch
  revalidatePath('/dashboard/orders')
  revalidateTag(`orders-${user.id}`)     // tag-based invalidation

  // 5. Redirect or return success
  redirect(`/orders/${order.id}`)
}

// Action with return value (no redirect)
export async function updateOrderStatus(orderId: string, status: string) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) return { error: 'Unauthorized' }

  const { error } = await supabase
    .from('orders')
    .update({ status })
    .eq('id', orderId)
    .eq('user_id', user.id)    // RLS + explicit check

  if (error) return { error: error.message }

  revalidatePath(`/orders/${orderId}`)
  return { success: true }
}
```

### Call from a Client Component
```typescript
// components/CreateOrderButton.tsx
'use client'
import { createOrder } from '@/app/actions/orders'
import { useFormStatus, useActionState } from 'react'

function SubmitButton() {
  const { pending } = useFormStatus()
  return <button disabled={pending}>{pending ? 'Creating...' : 'Create Order'}</button>
}

export function CreateOrderForm() {
  const [state, action] = useActionState(createOrder, undefined)

  return (
    <form action={action}>
      {state?.error?._form && (
        <p style={{ color: 'red' }}>{state.error._form.join(', ')}</p>
      )}
      <input type="hidden" name="items" value={JSON.stringify(items)} />
      <SubmitButton />
    </form>
  )
}
```

### Call directly from a Server Component
```typescript
// No 'use client' needed
import { updateOrderStatus } from '@/app/actions/orders'

export default async function OrderPage({ params }) {
  return (
    <form action={updateOrderStatus.bind(null, params.id, 'cancelled')}>
      <button type="submit">Cancel Order</button>
    </form>
  )
}
```

