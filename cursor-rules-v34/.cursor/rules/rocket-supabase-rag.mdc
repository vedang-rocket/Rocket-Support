## Complete RAG Pipeline

### Step 1 — Ingest: chunk, embed, store

```typescript
// app/api/documents/ingest/route.ts
import { chunkText } from '@/lib/chunker'
import { generateEmbedding } from '@/lib/embeddings'
import { createClient } from '@/lib/supabase/server'

export async function POST(request: Request) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) return Response.json({ error: 'Unauthorized' }, { status: 401 })

  const { documentName, content } = await request.json()

  // 1. Create parent document record
  const { data: doc, error: docErr } = await supabase
    .from('documents')
    .insert({ name: documentName, created_by: user.id })
    .select().single()
  if (docErr) return Response.json({ error: docErr.message }, { status: 500 })

  // 2. Chunk the content
  const chunks = chunkText(content)

  // 3. Embed each chunk and insert
  const sections = await Promise.all(
    chunks.map(async (chunk, i) => ({
      document_id: doc.id,
      content: chunk,
      embedding: await generateEmbedding(chunk),
    }))
  )

  const { error: sectErr } = await supabase
    .from('document_sections')
    .insert(sections)

  if (sectErr) return Response.json({ error: sectErr.message }, { status: 500 })
  return Response.json({ documentId: doc.id, chunks: chunks.length })
}
```

### Step 2 — Retrieve: match function with RLS

```sql
-- Match function respects RLS via SECURITY INVOKER (default)
CREATE OR REPLACE FUNCTION match_document_sections(
  query_embedding VECTOR(1536),
  match_threshold FLOAT DEFAULT 0.78,
  match_count     INT   DEFAULT 5,
  in_document_ids BIGINT[] DEFAULT NULL  -- optional: filter to specific docs
)
RETURNS TABLE(id BIGINT, content TEXT, similarity FLOAT, document_id BIGINT)
LANGUAGE sql STABLE SECURITY INVOKER AS $$
  SELECT
    ds.id,
    ds.content,
    1 - (ds.embedding <=> query_embedding) AS similarity,
    ds.document_id
  FROM document_sections ds
  WHERE ds.embedding IS NOT NULL
    AND (in_document_ids IS NULL OR ds.document_id = ANY(in_document_ids))
    AND 1 - (ds.embedding <=> query_embedding) > match_threshold
  ORDER BY ds.embedding <=> query_embedding
  LIMIT match_count;
$$;
```

### Step 3 — Augment: build context prompt

```typescript
// lib/rag.ts
import { generateEmbedding } from '@/lib/embeddings'

export async function retrieveContext(supabase: any, question: string, maxChunks = 5) {
  const queryEmbedding = await generateEmbedding(question)

  const { data: sections, error } = await supabase.rpc('match_document_sections', {
    query_embedding: queryEmbedding,
    match_threshold: 0.75,
    match_count: maxChunks,
  })

  if (error || !sections?.length) return null

  // Build context string from retrieved chunks
  const context = sections
    .map((s: any, i: number) => `[Source ${i + 1}]:\n${s.content}`)
    .join('\n\n---\n\n')

  return context
}

export function buildRAGPrompt(question: string, context: string): string {
  return `You are a helpful assistant. Answer the question based ONLY on the provided context.
If the context does not contain enough information, say "I don't have enough information to answer that."

Context:
${context}

Question: ${question}

Answer:`
}
```

### Step 4 — Generate + Stream response

```typescript
// app/api/chat/route.ts
import { OpenAI } from 'openai'
import { retrieveContext, buildRAGPrompt } from '@/lib/rag'
import { createClient } from '@/lib/supabase/server'

const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY })

export async function POST(request: Request) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) return Response.json({ error: 'Unauthorized' }, { status: 401 })

  const { question } = await request.json()

  // Retrieve relevant context (RLS enforced via server client)
  const context = await retrieveContext(supabase, question)
  if (!context) {
    return Response.json({ answer: "I don't have any relevant documents to answer that." })
  }

  const prompt = buildRAGPrompt(question, context)

  // Stream the response back to the client
  const stream = await openai.chat.completions.create({
    model: 'gpt-4o-mini',      // cheapest capable model
    messages: [{ role: 'user', content: prompt }],
    stream: true,
    max_tokens: 500,
  })

  // Return a streaming response
  const encoder = new TextEncoder()
  const readable = new ReadableStream({
    async start(controller) {
      for await (const chunk of stream) {
        const text = chunk.choices[0]?.delta?.content ?? ''
        if (text) controller.enqueue(encoder.encode(`data: ${JSON.stringify({ text })}\n\n`))
      }
      controller.enqueue(encoder.encode('data: [DONE]\n\n'))
      controller.close()
    }
  })

  return new Response(readable, {
    headers: { 'Content-Type': 'text/event-stream', 'Cache-Control': 'no-cache' }
  })
}
```

```typescript
// Client: consume the SSE stream
// 'use client' component
const askQuestion = async (question: string) => {
  setAnswer('')
  const response = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ question }),
  })

  const reader = response.body!.getReader()
  const decoder = new TextDecoder()

  while (true) {
    const { done, value } = await reader.read()
    if (done) break
    const chunk = decoder.decode(value)
    const lines = chunk.split('\n').filter(l => l.startsWith('data: '))
    for (const line of lines) {
      const data = line.replace('data: ', '')
      if (data === '[DONE]') break
      const { text } = JSON.parse(data)
      setAnswer(prev => prev + text)
    }
  }
}
```

