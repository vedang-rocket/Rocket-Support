## Hybrid Search — Semantic + Keyword Combined

```sql
-- Hybrid search using RRF (Reciprocal Rank Fusion)
-- Combines pgvector similarity with full-text search rankings
CREATE OR REPLACE FUNCTION hybrid_search(
  query_text        TEXT,
  query_embedding   VECTOR(1536),
  match_count       INT DEFAULT 10,
  full_text_weight  FLOAT DEFAULT 1.0,
  semantic_weight   FLOAT DEFAULT 1.0,
  rrf_k             INT DEFAULT 50
)
RETURNS TABLE(id BIGINT, content TEXT, document_id BIGINT, rrf_score FLOAT)
LANGUAGE sql STABLE SECURITY INVOKER AS $$
WITH
  -- Full-text search ranked results
  fts AS (
    SELECT id, content, document_id,
           ROW_NUMBER() OVER (ORDER BY ts_rank(to_tsvector('english', content),
                                               websearch_to_tsquery('english', query_text)) DESC) AS rank
    FROM document_sections
    WHERE to_tsvector('english', content) @@ websearch_to_tsquery('english', query_text)
    LIMIT match_count * 2
  ),
  -- Semantic search ranked results
  semantic AS (
    SELECT id, content, document_id,
           ROW_NUMBER() OVER (ORDER BY embedding <=> query_embedding) AS rank
    FROM document_sections
    WHERE embedding IS NOT NULL
    ORDER BY embedding <=> query_embedding
    LIMIT match_count * 2
  )
SELECT
  COALESCE(fts.id, semantic.id)                AS id,
  COALESCE(fts.content, semantic.content)      AS content,
  COALESCE(fts.document_id, semantic.document_id) AS document_id,
  -- RRF formula: weight / (k + rank)
  COALESCE(1.0 / (rrf_k + fts.rank), 0)    * full_text_weight +
  COALESCE(1.0 / (rrf_k + semantic.rank), 0) * semantic_weight AS rrf_score
FROM fts
FULL OUTER JOIN semantic ON fts.id = semantic.id
ORDER BY rrf_score DESC
LIMIT match_count;
$$;
```

```typescript
// Call hybrid search
const { data } = await supabase.rpc('hybrid_search', {
  query_text: question,
  query_embedding: queryEmbedding,
  match_count: 5,
})
```

