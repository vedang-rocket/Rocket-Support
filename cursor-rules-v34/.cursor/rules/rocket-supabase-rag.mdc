## Document Chunking — The Most Critical Step

Embedding entire documents produces poor results. Chunk first.

```typescript
// lib/chunker.ts
export function chunkText(text: string, options = {
  chunkSize: 800,      // characters per chunk
  overlap: 100,        // characters of overlap between chunks
}): string[] {
  const { chunkSize, overlap } = options
  const chunks: string[] = []
  let start = 0

  while (start < text.length) {
    const end = Math.min(start + chunkSize, text.length)
    let chunk = text.slice(start, end)

    // Try to break at sentence boundary (don't cut mid-sentence)
    if (end < text.length) {
      const lastPeriod = chunk.lastIndexOf('. ')
      const lastNewline = chunk.lastIndexOf('\n')
      const breakAt = Math.max(lastPeriod, lastNewline)
      if (breakAt > chunkSize * 0.5) {
        chunk = text.slice(start, start + breakAt + 1)
      }
    }

    if (chunk.trim().length > 50) chunks.push(chunk.trim())
    start += chunk.length - overlap
  }

  return chunks
}

// Chunking guidelines:
// 800-1000 chars = good for prose/articles (fits ~500 tokens)
// 400-600 chars = better for code/technical docs
// 100 char overlap = prevents splitting important context at boundaries
```

