## Automatic Embeddings via Trigger + pg_net

```sql
-- Auto-embed when a document_section is inserted (no manual API call needed)
CREATE OR REPLACE FUNCTION trigger_embed_section()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  -- Call Edge Function to generate embedding async (pg_net — non-blocking)
  PERFORM net.http_post(
    url     := current_setting('app.supabase_url') || '/functions/v1/embed-section',
    headers := jsonb_build_object(
      'Content-Type',  'application/json',
      'Authorization', 'Bearer ' || current_setting('app.service_role_key')
    ),
    body    := jsonb_build_object('sectionId', NEW.id, 'content', NEW.content)
  );
  RETURN NEW;
END;
$$;

CREATE TRIGGER on_section_inserted
  AFTER INSERT ON document_sections
  FOR EACH ROW WHEN (NEW.embedding IS NULL)
  EXECUTE FUNCTION trigger_embed_section();
```

```typescript
// supabase/functions/embed-section/index.ts
Deno.serve(async (req) => {
  const { sectionId, content } = await req.json()
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SECRET_KEY') ?? Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  )

  // Use built-in model (free) or OpenAI
  const session = new Supabase.ai.Session('gte-small')
  const embedding = await session.run(content, { mean_pool: true, normalize: true })

  await supabase.from('document_sections')
    .update({ embedding: Array.from(embedding) })
    .eq('id', sectionId)

  return new Response(JSON.stringify({ ok: true }))
})
```
