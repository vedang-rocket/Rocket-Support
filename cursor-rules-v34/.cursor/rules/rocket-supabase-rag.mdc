## RAG with RLS Permissions

### Pattern 1 — User-owned documents (most common)
```sql
-- Users can only search their own document sections
CREATE POLICY "users_own_sections" ON document_sections FOR SELECT
USING (
  EXISTS (
    SELECT 1 FROM documents d
    WHERE d.id = document_sections.document_id
      AND d.created_by = auth.uid()
  )
);

CREATE POLICY "users_own_documents" ON documents FOR ALL
USING (created_by = auth.uid());
```

### Pattern 2 — Shared document access via permissions table
```sql
CREATE TABLE document_permissions (
  document_id BIGINT REFERENCES documents(id) ON DELETE CASCADE,
  user_id     UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  PRIMARY KEY (document_id, user_id)
);

ALTER TABLE document_permissions ENABLE ROW LEVEL SECURITY;

CREATE POLICY "sections_with_permission" ON document_sections FOR SELECT
USING (
  EXISTS (
    SELECT 1 FROM document_permissions dp
    WHERE dp.document_id = document_sections.document_id
      AND dp.user_id = auth.uid()
  )
  OR EXISTS (
    SELECT 1 FROM documents d
    WHERE d.id = document_sections.document_id
      AND d.created_by = auth.uid()
  )
);
```

