## Step 4 — Rate Limiting via PostgREST pre-request Hook

PostgREST supports a pre-request function that runs before every API request.
Use it to implement rate limiting without any middleware.

```sql
-- 1. Create a private schema for rate limiting (never exposed via PostgREST)
CREATE SCHEMA IF NOT EXISTS private;

-- 2. Create rate limit tracking table
CREATE TABLE IF NOT EXISTS private.rate_limits (
  ip          TEXT NOT NULL,
  endpoint    TEXT NOT NULL DEFAULT 'api',
  window_start TIMESTAMPTZ NOT NULL DEFAULT date_trunc('minute', NOW()),
  request_count INTEGER NOT NULL DEFAULT 1,
  PRIMARY KEY (ip, endpoint, window_start)
);

-- 3. Create the pre-request function
CREATE OR REPLACE FUNCTION private.check_rate_limit()
RETURNS void LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE
  v_ip       TEXT := current_setting('request.headers', true)::json->>'x-forwarded-for';
  v_count    INTEGER;
  v_limit    INTEGER := 100;  -- requests per minute per IP
BEGIN
  IF v_ip IS NULL OR v_ip = '' THEN RETURN; END IF;

  INSERT INTO private.rate_limits(ip, window_start, request_count)
  VALUES (v_ip, date_trunc('minute', NOW()), 1)
  ON CONFLICT (ip, endpoint, window_start)
  DO UPDATE SET request_count = private.rate_limits.request_count + 1
  RETURNING request_count INTO v_count;

  IF v_count > v_limit THEN
    RAISE EXCEPTION 'Rate limit exceeded'
      USING HINT = 'Too many requests', ERRCODE = 'P0001';
  END IF;
END;
$$;

-- 4. Register as PostgREST pre-request (run in SQL Editor)
ALTER ROLE authenticator SET pgrst.db_pre_request = 'private.check_rate_limit';

-- 5. Reload PostgREST config
NOTIFY pgrst, 'reload config';

-- 6. Clean up old rate limit windows (add to pg_cron)
SELECT cron.schedule('cleanup-rate-limits', '*/5 * * * *', $$
  DELETE FROM private.rate_limits WHERE window_start < NOW() - INTERVAL '5 minutes';
$$);
```

