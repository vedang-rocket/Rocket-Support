## Netlify Image CDN vs Supabase Storage CDN

```typescript
// Netlify Image CDN — transforms images on the fly at Netlify's edge
// URL format: /.netlify/images?url=[source]&w=200&h=200&fit=cover

// Use Netlify Image CDN when:
// - Images come from external URLs
// - You want format conversion without next/image

// Use Supabase Storage transforms when:
// - Images are stored in Supabase Storage buckets
// - You need signed URLs (private images)
// - You want to avoid Netlify image transform costs

// next.config.ts — choose ONE approach
const nextConfig = {
  images: {
    // Option A: Supabase Storage
    remotePatterns: [{
      protocol: 'https',
      hostname: '[REF].supabase.co',
      pathname: '/storage/v1/object/public/**',
    }],
    // Option B: Netlify Image CDN (uncomment and remove remotePatterns)
    // loader: 'custom',
    // loaderFile: './lib/netlify-image-loader.ts',
  },
}
```

