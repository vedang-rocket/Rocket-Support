## getClaims() vs getUser() — Performance vs Security

```typescript
// getUser() — validates JWT with Supabase server (network call ~50-200ms)
// Use for: any operation that reads or writes sensitive data
const { data: { user } } = await supabase.auth.getUser()

// getClaims() — validates JWT signature locally (microseconds, no network)
// Use for: middleware checks, role-based routing, non-sensitive reads
const { data: claims } = await supabase.auth.getClaims()
// claims = { sub: 'user-uuid', email: '...', user_role: 'admin', aal: 'aal1' }
```

```typescript
// middleware.ts — USE getClaims() here (runs on every request)
export async function middleware(request: NextRequest) {
  const supabase = createServerClient(/* ... */)

  // getClaims() is microseconds — safe to call on every request
  const { data: claims } = await supabase.auth.getClaims()

  // Protect /admin route — check role from JWT claims locally
  if (request.nextUrl.pathname.startsWith('/admin')) {
    if (!claims || claims.user_role !== 'admin') {
      return NextResponse.redirect(new URL('/', request.url))
    }
  }

  return response
}

// app/api/payments/route.ts — USE getUser() for sensitive operations
export async function POST(request: NextRequest) {
  const supabase = await createClient()
  // getUser() validates with server — catches revoked tokens
  const { data: { user }, error } = await supabase.auth.getUser()
  if (error || !user) return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
  // Now safe to process payment
}
```

