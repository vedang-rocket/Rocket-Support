# Supabase Auth — Advanced Features Reference

---

## Multi-Factor Authentication (MFA)

Supabase supports TOTP (authenticator app like Google Authenticator / Authy) and Phone SMS.
Free on all plans. Enabled by default — no setup required.

### How MFA works — Assurance Levels
```
aal1 = logged in with email/password, OAuth, magic link (first factor only)
aal2 = logged in with first factor + MFA code (full MFA verification)

nextLevel = aal2  → user has a verified MFA factor, must complete it
nextLevel = aal1  → user has no MFA factor set up
```

### Step 1 — Enrollment (user sets up MFA)
```typescript
// In a 'use client' component
'use client'
import { useState, useEffect } from 'react'
import { createClient } from '@/lib/supabase/client'

export function MFAEnrollment() {
  const [qrCode, setQrCode] = useState<string>('')
  const [factorId, setFactorId] = useState<string>('')
  const [verifyCode, setVerifyCode] = useState('')
  const supabase = createClient()

  useEffect(() => {
    // Start enrollment — get QR code to show user
    supabase.auth.mfa.enroll({ factorType: 'totp' })
      .then(({ data, error }) => {
        if (data) {
          setQrCode(data.totp.qr_code)   // SVG string — use as <img src={qrCode}>
          setFactorId(data.id)
        }
      })
  }, [])

  const verify = async () => {
    // User scanned QR and entered the 6-digit code
    const { data: challengeData } = await supabase.auth.mfa.challenge({ factorId })
    const { error } = await supabase.auth.mfa.verify({
      factorId,
      challengeId: challengeData!.id,
      code: verifyCode,
    })
    if (!error) {
      // MFA enrollment complete — user now has aal2
    }
  }

  return (
    <div>
      <img src={qrCode} alt="Scan with authenticator app" />
      <input value={verifyCode} onChange={e => setVerifyCode(e.target.value)} />
      <button onClick={verify}>Enable MFA</button>
    </div>
  )
}
```

### Step 2 — Challenge on login (require MFA after sign in)
```typescript
// Wrap your app component to enforce MFA check
export function AppWithMFA({ children }: { children: React.ReactNode }) {
  const [readyToShow, setReadyToShow] = useState(false)
  const [showMFAChallenge, setShowMFAChallenge] = useState(false)
  const supabase = createClient()

  useEffect(() => {
    supabase.auth.mfa.getAuthenticatorAssuranceLevel().then(({ data }) => {
      if (data) {
        if (data.nextLevel === 'aal2' && data.nextLevel !== data.currentLevel) {
          setShowMFAChallenge(true)  // User has MFA but hasn't completed it
        }
      }
      setReadyToShow(true)
    })
  }, [])

  if (!readyToShow) return null
  if (showMFAChallenge) return <MFAChallenge onSuccess={() => setShowMFAChallenge(false)} />
  return <>{children}</>
}

// The challenge component
function MFAChallenge({ onSuccess }: { onSuccess: () => void }) {
  const [verifyCode, setVerifyCode] = useState('')
  const [error, setError] = useState('')
  const supabase = createClient()

  const submit = async () => {
    const factors = await supabase.auth.mfa.listFactors()
    const totpFactor = factors.data?.totp[0]
    if (!totpFactor) return

    const challenge = await supabase.auth.mfa.challenge({ factorId: totpFactor.id })
    const { error } = await supabase.auth.mfa.verify({
      factorId: totpFactor.id,
      challengeId: challenge.data!.id,
      code: verifyCode,
    })
    if (error) setError(error.message)
    else onSuccess()
  }

  return (
    <div>
      <p>Enter the code from your authenticator app:</p>
      {error && <p style={{ color: 'red' }}>{error}</p>}
      <input value={verifyCode} onChange={e => setVerifyCode(e.target.value)} maxLength={6} />
      <button onClick={submit}>Verify</button>
    </div>
  )
}
```

### Enforce MFA via RLS
```sql
-- Only allow access for users who completed MFA (aal2)
CREATE POLICY "require_mfa"
ON sensitive_table FOR ALL
USING (
  (SELECT auth.jwt() ->> 'aal') = 'aal2'
);
```

### Unenroll a factor
```typescript
const factors = await supabase.auth.mfa.listFactors()
const factorId = factors.data?.totp[0]?.id
if (factorId) {
  await supabase.auth.mfa.unenroll({ factorId })
}
```

