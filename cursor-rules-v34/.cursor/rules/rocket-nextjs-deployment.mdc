## Vercel Image Optimization

```typescript
// next.config.ts
import type { NextConfig } from 'next'

const nextConfig: NextConfig = {
  images: {
    remotePatterns: [
      {
        protocol: 'https',
        hostname: '[PROJECT_REF].supabase.co',
        pathname: '/storage/v1/object/public/**',
      },
      {
        protocol: 'https',
        hostname: '[PROJECT_REF].supabase.co',
        pathname: '/storage/v1/render/**',    // Supabase image transforms
      },
    ],
    formats: ['image/avif', 'image/webp'],   // avif first (smallest)
    minimumCacheTTL: 60 * 60 * 24 * 7,      // cache 7 days
    deviceSizes: [640, 750, 828, 1080, 1200, 1920],
  },
}
export default nextConfig
```

```tsx
import Image from 'next/image'

// ✅ always use next/image — automatic format, size, lazy load
<Image
  src={product.image_url}
  width={400}
  height={300}
  alt={product.name}
  priority={isAboveFold}    // true for LCP image only
  placeholder="blur"        // pair with blurDataURL for smooth loads
  quality={80}              // 80 = good quality/size balance
/>
```

