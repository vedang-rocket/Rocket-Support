## ISR — Vercel vs Netlify

```typescript
// ── Time-based ISR (both platforms) ──────────────────────────────────────
// ONLY for fully public, user-agnostic pages
export const revalidate = 3600   // revalidate every hour

// ❌ NEVER use revalidate on authenticated pages
// ✅ Always force-dynamic for any page that reads user data

// ── On-demand ISR via webhook (both platforms) ────────────────────────────
// app/api/revalidate/route.ts — called by Supabase Database Webhook on content change
import { revalidateTag, revalidatePath } from 'next/cache'
import { NextRequest, NextResponse }     from 'next/server'

export async function POST(req: NextRequest) {
  const secret = req.headers.get('x-revalidation-secret')
  if (secret !== process.env.REVALIDATION_SECRET) {
    return NextResponse.json({ error: 'unauthorized' }, { status: 401 })
  }
  const { table } = await req.json()

  if (table === 'products') {
    revalidateTag('products')
    revalidatePath('/products', 'layout')
  }
  if (table === 'blog_posts') {
    revalidatePath('/blog', 'layout')
  }

  return NextResponse.json({ revalidated: true, at: Date.now() })
}
```

