## Storage — File Uploads

### Setup: create a bucket
```
Supabase Dashboard → Storage → New bucket
Name: profile-images (or similar)
Public: false (use signed URLs for private, true for public CDN)
```

### Storage RLS policies (required even for public buckets for writes)
```sql
-- Allow authenticated users to upload their own files
CREATE POLICY "users_upload_own_files"
ON storage.objects FOR INSERT
WITH CHECK (
  bucket_id = 'profile-images'
  AND auth.uid()::TEXT = (storage.foldername(name))[1]
);

-- Allow public read on a public bucket
CREATE POLICY "public_read"
ON storage.objects FOR SELECT
USING (bucket_id = 'profile-images');

-- Allow users to delete their own files
CREATE POLICY "users_delete_own"
ON storage.objects FOR DELETE
USING (
  bucket_id = 'profile-images'
  AND auth.uid()::TEXT = (storage.foldername(name))[1]
);
```

### Upload a file (client-side)
```typescript
'use client'
export async function uploadProfileImage(file: File, userId: string) {
  const supabase = createClient()
  const fileExt = file.name.split('.').pop()
  const filePath = `${userId}/avatar.${fileExt}`  // folder = userId

  const { error } = await supabase.storage
    .from('profile-images')
    .upload(filePath, file, {
      upsert: true,        // overwrite if exists
      contentType: file.type
    })

  if (error) throw error

  // Get public URL (for public buckets)
  const { data } = supabase.storage
    .from('profile-images')
    .getPublicUrl(filePath)

  return data.publicUrl
}
```

### Signed URL (for private buckets)
```typescript
// Server-side — use server client
const supabase = await createClient()
const { data, error } = await supabase.storage
  .from('private-files')
  .createSignedUrl(filePath, 3600)  // expires in 1 hour

return data?.signedUrl  // use in <img src={signedUrl}>
```

### Image optimization (built-in)
```typescript
// Resize and transform images on the fly
const { data } = supabase.storage
  .from('profile-images')
  .getPublicUrl(filePath, {
    transform: {
      width: 100,
      height: 100,
      resize: 'cover',    // or 'contain' | 'fill'
      quality: 80,
    }
  })
```

### Next.js config for Supabase Storage images
```typescript
// next.config.ts — required for <Image> component
const nextConfig = {
  images: {
    remotePatterns: [
      {
        protocol: 'https',
        hostname: '[PROJECT_REF].supabase.co',
        pathname: '/storage/v1/object/public/**',
      },
    ],
  },
}
```

