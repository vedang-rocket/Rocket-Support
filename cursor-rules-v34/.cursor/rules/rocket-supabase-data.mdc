## Database Webhooks

Trigger HTTP requests on table changes (no pg_net needed — Supabase manages it).

```
Supabase Dashboard → Database → Webhooks → Create new webhook

Config:
- Table: orders
- Events: INSERT, UPDATE
- URL: https://your-app.netlify.app/api/webhooks/supabase
- HTTP method: POST
- Secret: [generate and store in env vars]
```

```typescript
// app/api/webhooks/supabase/route.ts
export async function POST(request: NextRequest) {
  // Verify the webhook secret
  const secret = request.headers.get('x-webhook-secret')
  if (secret !== process.env.SUPABASE_WEBHOOK_SECRET) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
  }

  const payload = await request.json()
  const { type, record, old_record, table } = payload

  if (table === 'orders' && type === 'INSERT') {
    // New order created — send confirmation email
    await sendOrderConfirmation(record)
  }

  return NextResponse.json({ ok: true })
}
```
