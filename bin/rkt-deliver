#!/usr/bin/env bash
# ============================================================
#  rkt-deliver — Package and deliver a fixed Rocket.new project
#  Usage: rkt-deliver [workspace_path]
#         rkt-deliver --help
# ============================================================

RKT_HOME="${RKT_HOME:-$HOME/rocket-support}"
ENGINE_DIR="$RKT_HOME/engine"
PYTHON="$ENGINE_DIR/.venv/bin/python3"

GREEN=$'\033[0;32m'; BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'
YELLOW=$'\033[1;33m'; RED=$'\033[0;31m'; BOLD=$'\033[1m'; NC=$'\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC} $1"; }
info() { echo -e "  ${BLUE}▸${NC} $1"; }
warn() { echo -e "  ${YELLOW}⚠${NC} $1"; }
fail() { echo -e "\n  ${RED}✗ ERROR:${NC} $1\n"; exit 1; }

# ── Help ──────────────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF

${BOLD}rkt-deliver${NC} — Package and deliver a fixed Rocket.new project

${BOLD}USAGE${NC}
  rkt-deliver
  rkt-deliver <workspace_path>
  rkt-deliver --help

${BOLD}ARGUMENTS${NC}
  workspace_path    Optional. Path to a specific workspace directory.
                    If omitted, the most recently created workspace is used.

${BOLD}EXAMPLES${NC}
  rkt-deliver
  rkt-deliver ~/rocket-support/workspace/wedcraft_20260416_123456

${BOLD}WHAT IT DOES${NC}
  1. Finds active workspace at ~/Documents/Rocket/<project>/fixed/<project>/
  2. Learns from any manual changes — diffs vs snapshot, saves to brain.db
  3. Strips tooling artifacts (node_modules, .next, .claude, .rkt_snapshot, etc.)
  4. Zips fixed/<project>/ → fixed/<project>_fixed.zip
  5. Reports: files learned, artifacts removed, zip path

${BOLD}ARTIFACTS REMOVED${NC}
  Folders : node_modules  .next  .claude  .cursor  .swarm  .claude-flow
            memory-bank  graphify-out  code-review-graph  .rkt_snapshot
  Files   : CLAUDE.md  AGENTS.md  .mcp.json  the-rocket-guide.md
            TROUBLESHOOTING.md  .rkt_meta.json  .rkt_handoff_prompt.md
            bun.lock  *.rkt_backup

${BOLD}ENGINE${NC}
  Python venv : $PYTHON
  Engine dir  : $ENGINE_DIR

EOF
}

# ── Guards ────────────────────────────────────────────────────────────────────

[[ "$1" == "--help" || "$1" == "-h" ]] && { show_help; exit 0; }
[[ ! -x "$PYTHON" ]] && fail "Python venv not found at $PYTHON\n  Run: cd $ENGINE_DIR && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"

# ── Resolve workspace ─────────────────────────────────────────────────────────

if [[ -n "${1:-}" ]]; then
    WORKSPACE_PATH="$(realpath "$1" 2>/dev/null || echo "$1")"
    [[ ! -d "$WORKSPACE_PATH" ]] && fail "Workspace directory not found: $WORKSPACE_PATH"
else
    WORKSPACE_PATH=$("$PYTHON" - <<PYEOF
import sys
sys.path.insert(0, "$ENGINE_DIR")
import workspace
m = workspace.get_active_workspace()
print(m['workspace_path'] if m else '')
PYEOF
)
    if [[ -z "$WORKSPACE_PATH" ]]; then
        echo -e "\n  ${RED}✗${NC} No active workspace. Run ${CYAN}rkt-triage${NC} first.\n"
        exit 1
    fi
fi

echo ""
info "Workspace: $WORKSPACE_PATH"
echo ""

# ── Deliver ───────────────────────────────────────────────────────────────────

echo -e "  ${BOLD}Learning from changes...${NC}"

DELIVER_JSON=$("$PYTHON" - <<PYEOF
import sys, json, warnings
warnings.filterwarnings("ignore")
sys.path.insert(0, "$ENGINE_DIR")
from deliverer import deliver
result = deliver(workspace_path="$WORKSPACE_PATH")
print(json.dumps(result))
PYEOF
)

if [[ $? -ne 0 || -z "$DELIVER_JSON" ]]; then
    fail "deliverer.deliver() failed"
fi

FILES_LEARNED=$(echo "$DELIVER_JSON" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['files_learned'])")
ARTIFACTS_N=$(echo   "$DELIVER_JSON" | "$PYTHON" -c "import sys,json; print(len(json.load(sys.stdin)['artifacts_removed']))")
ZIP_PATH=$(echo      "$DELIVER_JSON" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['zip_path'])")
ZIP_SIZE=$(echo      "$DELIVER_JSON" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['zip_size_kb'])")

# Shorten paths for display
ZIP_DISPLAY="${ZIP_PATH/#$HOME/\~}"
WORKING_DIR_DISPLAY="${WORKSPACE_PATH/#$HOME/\~}"

echo ""
ok "Learned from ${BOLD}${FILES_LEARNED}${NC} changed file(s)"
ok "Removed ${BOLD}${ARTIFACTS_N}${NC} artifact(s)"
ok "Fixed zip:   ${CYAN}${ZIP_DISPLAY}${NC} (${ZIP_SIZE} KB)"
ok "Working dir: ${CYAN}${WORKING_DIR_DISPLAY}${NC}"
echo ""
FIXED_FOLDER="$(dirname "$WORKSPACE_PATH")"
echo -e "  ${BOLD}${GREEN}Done.${NC} To open the fixed project:"
echo -e "  ${CYAN}open \"${FIXED_FOLDER}\"${NC}"
echo ""
