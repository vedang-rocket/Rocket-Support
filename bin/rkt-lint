#!/usr/bin/env python3
"""
rkt-lint — Static check of the 10 Rocket.new Hard Rules. Zero LLM. Zero tokens.
Usage: rkt-lint <project_path>
"""

import os
import re
import sys
from pathlib import Path
from typing import List, Tuple

RED    = "\033[0;31m"
YELLOW = "\033[1;33m"
GREEN  = "\033[0;32m"
CYAN   = "\033[0;36m"
BOLD   = "\033[1m"
NC     = "\033[0m"

_TEST_PATTERNS = ("/__tests__/", "/test/", ".test.ts", ".spec.ts", ".test.tsx", ".spec.tsx")

Violation = Tuple[str, str, str, str]  # (category, rule, file_path, detail)


def _is_test(path: str) -> bool:
    return any(p in path for p in _TEST_PATTERNS)


def _ts_files(root: Path, subdir: str = "") -> List[Path]:
    base = root / subdir if subdir else root
    if not base.exists():
        return []
    return [
        p for p in base.rglob("*.ts")
        if not _is_test(str(p)) and "node_modules" not in str(p)
    ] + [
        p for p in base.rglob("*.tsx")
        if not _is_test(str(p)) and "node_modules" not in str(p)
    ]


def _grep(path: Path, pattern: str) -> List[Tuple[int, str]]:
    """Return (line_no, line) for each match."""
    rx = re.compile(pattern)
    hits = []
    try:
        for i, line in enumerate(path.read_text(errors="replace").splitlines(), 1):
            if rx.search(line):
                hits.append((i, line.strip()))
    except OSError:
        pass
    return hits


def check(repo_path: str) -> List[Violation]:
    root = Path(repo_path).expanduser().resolve()
    violations: List[Violation] = []

    # Rule 1: getSession() in server code
    for p in _ts_files(root, "app") + _ts_files(root, "lib"):
        for lineno, line in _grep(p, r"\.getSession\(\)"):
            rel = str(p.relative_to(root))
            violations.append(("AUTH", "getSession() in server — use getUser()", rel, f"line {lineno}: {line[:60]}"))

    # Rule 2: request.json() in webhook handlers
    webhook_dir = root / "app" / "api" / "webhooks"
    for p in (webhook_dir.rglob("*.ts") if webhook_dir.exists() else []):
        for lineno, line in _grep(p, r"request\.json\(\)"):
            rel = str(p.relative_to(root))
            violations.append(("STRIPE", "request.json() in webhook — use request.text()", rel, f"line {lineno}: {line[:60]}"))

    # Rule 3: middleware.ts inside /app
    if (root / "app" / "middleware.ts").exists():
        violations.append(("AUTH", "middleware.ts in /app — move to project root", "app/middleware.ts", ""))

    # Rule 4: deprecated auth-helpers-nextjs import
    for p in _ts_files(root):
        for lineno, line in _grep(p, r"auth-helpers-nextjs"):
            rel = str(p.relative_to(root))
            violations.append(("SUPABASE", "@supabase/auth-helpers-nextjs (deprecated) — use @supabase/ssr", rel, f"line {lineno}"))
            break  # one violation per file

    # Rule 5: cookies() without await (Next.js 15)
    for p in _ts_files(root, "lib") + _ts_files(root, "utils"):
        content = p.read_text(errors="replace")
        # Match cookies() NOT preceded by "await " on same token
        for lineno, line in enumerate(content.splitlines(), 1):
            if re.search(r"(?<!await )cookies\(\)", line) and "import" not in line:
                rel = str(p.relative_to(root))
                violations.append(("AUTH", "cookies() without await (Next.js 15)", rel, f"line {lineno}: {line.strip()[:60]}"))
                break

    # Rule 6: NEXT_PUBLIC_ on service role key
    for env_file in root.glob(".env*"):
        if "node_modules" in str(env_file):
            continue
        for lineno, line in _grep(env_file, r"NEXT_PUBLIC_SUPABASE_SERVICE_ROLE|NEXT_PUBLIC_.*SERVICE_ROLE"):
            rel = str(env_file.relative_to(root))
            violations.append(("ENV", "NEXT_PUBLIC_ on service role key — remove NEXT_PUBLIC_ prefix", rel, f"line {lineno}"))

    # Rule 8: auth pages missing force-dynamic
    for p in _ts_files(root, "app"):
        if p.name not in ("page.tsx", "page.ts"):
            continue
        content = p.read_text(errors="replace")
        if "getUser()" in content and "force-dynamic" not in content:
            rel = str(p.relative_to(root))
            violations.append(("AUTH", "Auth page missing: export const dynamic = 'force-dynamic'", rel, ""))

    # Rule 9: CSP missing required domains in next.config
    for nc in ["next.config.ts", "next.config.js", "next.config.mjs"]:
        nc_path = root / nc
        if nc_path.exists():
            content = nc_path.read_text(errors="replace")
            if "Content-Security-Policy" in content or "content-security-policy" in content:
                missing = []
                required = {
                    "wss://*.supabase.co": "Supabase Realtime (WebSocket) blocked",
                    "https://*.supabase.co": "Supabase API blocked",
                    "https://static.rocket.new": "Rocket preview banner blocked",
                    "https://www.googletagmanager.com": "Google Tag Manager blocked",
                }
                for domain, label in required.items():
                    if domain not in content:
                        missing.append(label)
                if missing:
                    rel = str(nc_path.relative_to(root))
                    violations.append(("BUILD", f"CSP missing domains: {'; '.join(missing)}", rel, "Add to connect-src/script-src in headers()"))
            break  # only check first next.config found

    return violations


def main():
    if len(sys.argv) < 2:
        print(f"Usage: rkt-lint <project_path>")
        sys.exit(1)

    repo_path = sys.argv[1]
    if not os.path.isdir(repo_path):
        print(f"{RED}Error: {repo_path} is not a directory{NC}")
        sys.exit(1)

    violations = check(repo_path)

    if not violations:
        print(f"\n{GREEN}[LINT] All clear — no hard-rule violations found{NC}\n")
        sys.exit(0)

    print(f"\n{BOLD}{RED}[LINT] {len(violations)} violation(s) found in {repo_path}{NC}\n")
    for cat, rule, filepath, detail in violations:
        color = RED if cat in ("AUTH", "STRIPE") else YELLOW
        print(f"  {color}{cat:<8}{NC} {rule:<55} {CYAN}{filepath}{NC}")
        if detail:
            print(f"           {detail}")
    print()
    sys.exit(1)


if __name__ == "__main__":
    main()
