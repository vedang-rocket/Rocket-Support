.claude/settings.json
# ──────────────────────────────────────────────────────────────
IGNEOF
  ok ".gitignore updated"
else
  ok ".gitignore already has rkt-main block"
fi

# ── Engine: Post-setup fingerprint + semgrep + DB seed ───────
ENGINE_SUMMARY=""
SEMGREP_SUMMARY=""
FP_SUMMARY=""

if $ENGINE_AVAILABLE; then
  echo ""
  echo -e "${BOLD}${CYAN}── Engine Intelligence ────────────────────────────${NC}"

  # ── E1. Fingerprint (may already have FP_JSON from step 7) ──
  echo -e "\n  ${BLUE}▸${NC} Fingerprinting project..."
  if [[ -z "${FP_JSON:-}" ]]; then
    FP_JSON=$("$ENGINE_VENV" "$ENGINE_FP" --json "$PROJECT_DIR" 2>/dev/null)
  fi

  if [[ -n "$FP_JSON" ]]; then
    "$ENGINE_VENV" "$ENGINE_FP" "$PROJECT_DIR" 2>/dev/null | sed 's/^/  /'
    FP_SUMMARY="$FP_TYPE ($FP_CONFIDENCE) — $FP_FAILURE"
  else
    warn "Fingerprinter returned no output"
  fi

  # ── E2. Semgrep autofix scan ─────────────────────────────────
  echo -e "\n  ${BLUE}▸${NC} Running Semgrep autofix scan..."
  if [[ -f "$ENGINE_SEMGREP" ]]; then
    # First pass: count issues
    SEMGREP_JSON=$("$ENGINE_SEMGREP" \
      --config "$ENGINE_RULES" \
      --json --quiet --no-git-ignore \
      "$PROJECT_DIR" 2>/dev/null)

    ISSUE_COUNT=0
    if [[ -n "$SEMGREP_JSON" ]]; then
      ISSUE_COUNT=$(echo "$SEMGREP_JSON" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(len(d.get('results',[])))" 2>/dev/null || echo 0)
    fi

    if [[ "$ISSUE_COUNT" -gt 0 ]]; then
      # Second pass: apply autofixes
      "$ENGINE_SEMGREP" \
        --config "$ENGINE_RULES" \
        --autofix --quiet --no-git-ignore \
        "$PROJECT_DIR" 2>/dev/null

      # Which files changed?
      CHANGED_FILES=$(echo "$SEMGREP_JSON" | python3 -c "
import sys, json
d = json.load(sys.stdin)
files = sorted(set(r.get('path','') for r in d.get('results', []) if r.get('extra',{}).get('fix')))
for f in files: print(f'    {f}')
" 2>/dev/null)

      ok "Semgrep: $ISSUE_COUNT issue(s) found and autofixed"
      [[ -n "$CHANGED_FILES" ]] && echo -e "  Files changed:\n$CHANGED_FILES"
      SEMGREP_SUMMARY="$ISSUE_COUNT violation(s) autofixed"
    else
      ok "Semgrep: no violations found"
      SEMGREP_SUMMARY="0 violations"
    fi
  else
    warn "semgrep not found in engine venv (run: pip install semgrep in .venv)"
    SEMGREP_SUMMARY="skipped (semgrep not available)"
  fi

  # ── E3. Seed fix database with this project fingerprint ──────
  echo -e "\n  ${BLUE}▸${NC} Saving fingerprint to fix database..."
  if [[ -n "$FP_JSON" ]]; then
    echo "$FP_JSON" | "$ENGINE_VENV" "$ENGINE_DIR/seed_project.py"
  else
    skip "No fingerprint data to save"
  fi

  # E4 — Claude diagnosis runs unconditionally below the Done banner

  echo ""
  echo -e "${BOLD}${CYAN}──────────────────────────────────────────────────${NC}"
fi

# ── Done ──────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BOLD}  $PROJECT is ready${NC}"
echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "  ${BOLD}Code:${NC}   $PROJECT_DIR"
echo -e "  ${BOLD}Vault:${NC}  $VAULT_DIR"
echo ""
echo -e "  ${BOLD}Tools installed:${NC}"
echo -e "  ✓ v34 Cursor rules (61 rules, 40 commands)"
echo -e "  ✓ Graphify (PreToolUse hook — graph before grep)"
echo -e "  ✓ UI/UX Pro Max (auto-activates on UI requests)"
echo -e "  ✓ MCP: Context7 + Sequential Thinking + Memory + Playwright"
echo -e "  ✓ code-review-graph"
echo -e "  ✓ Obsidian vault"
echo -e "  ✓ RuFlo V3 daemon"
if $ENGINE_AVAILABLE; then
  echo -e "  ✓ Engine: ${FP_SUMMARY:-fingerprint saved to brain.db}"
  echo -e "  ✓ Semgrep: ${SEMGREP_SUMMARY:-scan complete}"
fi
echo ""

if $RUN_DIAGNOSE; then
  echo -e "  ${BOLD}${CYAN}Running full Claude diagnosis...${NC}"
  echo ""
  rkt --local "$PROJECT_DIR"
else
  echo -e "  ${BOLD}Start working:${NC}"
  echo -e "  1. ${BOLD}Cursor${NC}    → Open Folder → $PROJECT_DIR → /audit-codebase"
  echo -e "  2. ${BOLD}Obsidian${NC}  → Open vault  → $VAULT_DIR"
  echo -e "  3. ${BOLD}Claude Code${NC} → cd $PROJECT_DIR && claude"
  echo ""
fi
