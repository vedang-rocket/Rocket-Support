# ── 10. RuFlo ─────────────────────────────────────────────────
section 10 "RuFlo V3 — agent swarm + memory"
if ! command -v ruflo >/dev/null 2>&1; then
  info "Installing ruflo..."
  npm install -g ruflo --quiet 2>/dev/null || warn "ruflo install failed"
fi

if command -v ruflo >/dev/null 2>&1; then
  cd "$PROJECT_DIR"
  ruflo init --force 2>/dev/null && ok "ruflo initialized" || warn "ruflo init failed"
  ruflo memory init --force 2>/dev/null && ok "ruflo memory initialized" || warn "ruflo memory init failed"
  info "Starting daemon..."
  ruflo start --daemon 2>/dev/null
  RUFLO_OK=false
  for i in 1 2 3 4 5; do
    sleep 2
    ruflo status 2>/dev/null | grep -qiE "running|active|healthy|started" && RUFLO_OK=true && break
  done
  $RUFLO_OK && ok "RuFlo daemon running" || warn "RuFlo started — check with: ruflo doctor"
else
  skip "ruflo not found"
fi

# ── 6b. Merge MCP servers into .mcp.json (after RuFlo) ───────
# RuFlo creates its own .mcp.json — we now merge ours into it
PROJECT_DIR="$PROJECT_DIR" python3 - << 'PYEOF'
import json, os

mcp_path = os.path.join(os.environ.get("PROJECT_DIR", "."), ".mcp.json")

existing = {}
if os.path.exists(mcp_path):
    try:
        with open(mcp_path) as f:
            existing = json.load(f)
    except:
        existing = {}

if "mcpServers" not in existing:
    existing["mcpServers"] = {}

new_servers = {
    "context7": {"command": "npx", "args": ["-y", "@upstash/context7-mcp@latest"]},
    "sequential-thinking": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]},
    "memory": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"]},
    "playwright": {"command": "npx", "args": ["@playwright/mcp@latest"]}
}

for name, config in new_servers.items():
    existing["mcpServers"][name] = config

with open(mcp_path, 'w') as f:
    json.dump(existing, f, indent=2)

servers = list(existing["mcpServers"].keys())
print(f"  \033[0;32m✓\033[0m .mcp.json has {len(servers)} servers: {', '.join(servers)}")
PYEOF

# ── 11. .gitignore ────────────────────────────────────────────
