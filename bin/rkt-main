#!/usr/bin/env bash
# ============================================================
#  rkt-main — Rocket.new Full Project Setup
#  Usage: rkt-main <project-name> [--force] [--no-diagnose]
# ============================================================

RKT_HOME="${RKT_HOME:-$HOME/rocket-support}"
ROCKET_BASE="git@github-rocket:vedang-rocket"
ROCKET_DIR="$HOME/Documents/Rocket"
OBSIDIAN_DIR="$HOME/Documents/Obsidian"
V34_ZIP="$HOME/Downloads/rocket-cursor-rules-v34-final.zip"
V34_DIR="$RKT_HOME/cursor-rules-v34"
TOTAL_STEPS=11
GLOBAL_MCP="$HOME/.claude/mcp.json"

# ── Engine paths ─────────────────────────────────────────────
ENGINE_DIR="$RKT_HOME/engine"
ENGINE_VENV="$ENGINE_DIR/.venv/bin/python3"
ENGINE_SEMGREP="$ENGINE_DIR/.venv/bin/semgrep"
ENGINE_FP="$ENGINE_DIR/fingerprint.py"
ENGINE_SMART="$ENGINE_DIR/rkt_smart.py"
ENGINE_RULES="$ENGINE_DIR/rules"
ENGINE_AVAILABLE=false
[[ -f "$ENGINE_VENV" && -f "$ENGINE_FP" ]] && ENGINE_AVAILABLE=true

GREEN='\033[0;32m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; RED='\033[0;31m'; BOLD='\033[1m'; NC='\033[0m'

ok()      { echo -e "  ${GREEN}✓${NC} $1"; }
info()    { echo -e "  ${BLUE}▸${NC} $1"; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $1"; }
fail()    { echo -e "\n  ${RED}✗ ERROR:${NC} $1\n"; exit 1; }
skip()    { echo -e "  ${YELLOW}–${NC} $1 (skipped)"; }
section() { echo -e "\n${BOLD}${CYAN}[$1/$TOTAL_STEPS] $2${NC}"; }


# ── Global one-time MCP setup (runs silently, skips if already done) ─
setup_global_mcp() {
  python3 - << 'PYEOF'
import json, os

mcp_path = os.path.expanduser("~/.claude/mcp.json")
os.makedirs(os.path.expanduser("~/.claude"), exist_ok=True)

existing = {}
if os.path.exists(mcp_path):
    try:
        with open(mcp_path) as f:
            existing = json.load(f)
    except:
        existing = {}

if "mcpServers" not in existing:
    existing["mcpServers"] = {}

new_servers = {
    "context7": {"command": "npx", "args": ["-y", "@upstash/context7-mcp@latest"]},
    "sequential-thinking": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]},
    "memory": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"]},
    "playwright": {"command": "npx", "args": ["@playwright/mcp@latest"]}
}

added = []
for name, config in new_servers.items():
    if name not in existing["mcpServers"]:
        existing["mcpServers"][name] = config
        added.append(name)

with open(mcp_path, 'w') as f:
    json.dump(existing, f, indent=2)

if added:
    print(f"  \033[0;32m✓\033[0m Global MCPs added: {', '.join(added)}")
else:
    print(f"  \033[0;32m✓\033[0m Global MCPs already configured")
PYEOF
}

setup_global_mcp


if [[ $# -eq 0 ]]; then
  echo -e "\n${BOLD}rkt-main${NC} — Full Rocket.new project setup"
  echo -e "Usage:   rkt-main <project-name> [--force] [--no-diagnose]"
  echo -e "         rkt-main --local /path/to/project   → use local folder, skip clone"
  echo -e "         rkt-main /path/to/project           → shorthand for --local"
  echo -e "         --force        Redo all 11 steps even if project already exists"
  echo -e "         --no-diagnose  Skip Claude diagnosis (fast scan only)"
  echo -e "Example: rkt-main cliently                  → clone from GitHub + full setup"
  echo -e "         rkt-main --local ~/Downloads/myproject → local folder + full setup"
  echo -e "         rkt-main /path/to/project          → shorthand for --local"
  echo -e "         rkt-main cliently --force           → redo all 11 steps + scan + Claude"
  echo -e "         rkt-main cliently --no-diagnose     → setup + scan only, no Claude\n"
  exit 0
fi

PROJECT="$1"
RUN_DIAGNOSE=true
RUN_FORCE=false
RUN_LOCAL=false
LOCAL_PATH=""
for _arg in "${@:2}"; do
  [[ "$_arg" == "--no-diagnose" ]] && RUN_DIAGNOSE=false
  [[ "$_arg" == "--force" ]]       && RUN_FORCE=true
  [[ "$_arg" == "--local" ]]       && RUN_LOCAL=true
done
# If first arg is a path (starts with / or ~), treat as --local
if [[ "$1" == /* || "$1" == ~* ]]; then
  RUN_LOCAL=true
  LOCAL_PATH="${1/#\~/$HOME}"
  PROJECT="${LOCAL_PATH##*/}"
fi
# If --local flag with path as next arg
if $RUN_LOCAL && [[ -z "$LOCAL_PATH" && $# -ge 2 ]]; then
  LOCAL_PATH="${2/#\~/$HOME}"
  PROJECT="${LOCAL_PATH##*/}"
fi

if $RUN_LOCAL; then
  [[ -z "$LOCAL_PATH" ]] && fail "--local requires a path (e.g. rkt-main --local ~/Downloads/myproject)"
  [[ -d "$LOCAL_PATH" ]] || fail "Local path not found: $LOCAL_PATH"
  REPO_URL="local"
  PROJECT_DIR="$LOCAL_PATH"
else
  REPO_URL="$ROCKET_BASE/${PROJECT}.git"
  PROJECT_DIR="$ROCKET_DIR/$PROJECT"
fi
VAULT_DIR="$OBSIDIAN_DIR/$PROJECT"

echo -e "\n${BOLD}rkt-main${NC} → ${BOLD}$PROJECT${NC}"
if $RUN_LOCAL; then
  echo -e "Mode:  local folder"
  echo -e "Code:  $PROJECT_DIR"
else
  echo -e "Repo:  $REPO_URL"
  echo -e "Code:  $PROJECT_DIR"
fi
echo -e "Vault: $VAULT_DIR\n"

# ── Already set up? Skip straight to engine unless --force ────
_is_setup=false
if [[ -d "$PROJECT_DIR/.cursor" && -f "$PROJECT_DIR/CLAUDE.md" ]]; then
  _is_setup=true
fi
# Local paths count as already set up only if explicitly flagged
if $RUN_LOCAL && ! $RUN_FORCE; then
  _is_setup=false
fi

if $_is_setup && ! $RUN_FORCE; then
  echo -e "  ${GREEN}✓${NC} Project already set up — running engine intelligence only"
  echo -e "  ${YELLOW}–${NC} Use ${BOLD}--force${NC} to redo all 11 steps\n"

  # Jump straight to engine block — reuse FP_JSON vars needed later
  FP_JSON=""; FP_TYPE="Unknown"; FP_CONFIDENCE="?"; FP_FAILURE="Unknown"
  FP_CATEGORY="OTHER"; FP_FRAMEWORK="Next.js"; FP_NEXT_VERSION="unknown"
  FP_HAS_SUPABASE="false"; FP_HAS_STRIPE="false"; FP_SQL_FILES=0

  if $ENGINE_AVAILABLE; then
    echo -e "${BOLD}${CYAN}── Engine Intelligence ────────────────────────────${NC}"

    echo -e "\n  ${BLUE}▸${NC} Fingerprinting project..."
    FP_JSON=$("$ENGINE_VENV" "$ENGINE_FP" --json "$PROJECT_DIR" 2>/dev/null)
    if [[ -n "$FP_JSON" ]]; then
      "$ENGINE_VENV" "$ENGINE_FP" "$PROJECT_DIR" 2>/dev/null | sed 's/^/  /'
      FP_TYPE=$(echo "$FP_JSON"        | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('project_type','Unknown'))")
      FP_CONFIDENCE=$(echo "$FP_JSON"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(f\"{d.get('confidence',0):.0%}\")")
      FP_FAILURE=$(echo "$FP_JSON"     | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('common_failure',''))")
    fi

    echo -e "\n  ${BLUE}▸${NC} Running Semgrep autofix scan..."
    if [[ -f "$ENGINE_SEMGREP" ]]; then
      SEMGREP_JSON=$("$ENGINE_SEMGREP" --config "$ENGINE_RULES" --json --quiet --no-git-ignore "$PROJECT_DIR" 2>/dev/null)
      ISSUE_COUNT=0
      [[ -n "$SEMGREP_JSON" ]] && ISSUE_COUNT=$(echo "$SEMGREP_JSON" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(len(d.get('results',[])))" 2>/dev/null || echo 0)
      if [[ "$ISSUE_COUNT" -gt 0 ]]; then
        "$ENGINE_SEMGREP" --config "$ENGINE_RULES" --autofix --quiet --no-git-ignore "$PROJECT_DIR" 2>/dev/null
        ok "Semgrep: $ISSUE_COUNT issue(s) found and autofixed"
      else
        ok "Semgrep: no violations found"
      fi
    else
      skip "semgrep not in engine venv"
    fi

    echo -e "\n  ${BLUE}▸${NC} Saving fingerprint to fix database..."
    if [[ -n "$FP_JSON" ]]; then
      echo "$FP_JSON" | "$ENGINE_VENV" "$ENGINE_DIR/seed_project.py"
    else
      skip "No fingerprint data to save"
    fi

    echo ""
    echo -e "${BOLD}${CYAN}──────────────────────────────────────────────────${NC}"
  else
    warn "Engine not available (venv missing) — run: cd ~/rocket-support/engine && python3 -m venv .venv"
  fi

  echo ""
  echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BOLD}  $PROJECT — scan complete${NC}"
  echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  ${BOLD}Code:${NC}   $PROJECT_DIR"
  echo ""

  if $RUN_DIAGNOSE; then
    echo -e "  ${BOLD}${CYAN}Running full Claude diagnosis...${NC}"
    echo ""
    rkt --local "$PROJECT_DIR"
  fi
  exit 0
fi

# ── 1. Clone ──────────────────────────────────────────────────
section 1 "Clone repository"
if $RUN_LOCAL; then
  ok "Using local folder: $PROJECT_DIR"
else
  mkdir -p "$ROCKET_DIR"
  if [[ -d "$PROJECT_DIR/.git" ]]; then
    info "Already cloned — pulling latest..."
    git -C "$PROJECT_DIR" pull --quiet 2>/dev/null && ok "Pulled latest" || warn "Pull failed — using existing code"
  else
    info "Cloning $PROJECT..."
    git clone --quiet "$REPO_URL" "$PROJECT_DIR" || fail "Clone failed. Check name and SSH key."
    ok "Cloned → $PROJECT_DIR"
  fi

  # Fetch latest remote refs
  git -C "$PROJECT_DIR" fetch --all --quiet 2>/dev/null || true

  # Get most recently updated remote branch
  LATEST_BRANCH=$(git -C "$PROJECT_DIR" branch -r \
    --sort=-committerdate \
    2>/dev/null | grep -v 'HEAD' | head -1 | xargs | sed 's|origin/||')

  # Fallback chain
  if [[ -z "$LATEST_BRANCH" ]]; then
    LATEST_BRANCH="main"
  fi

  # Checkout and pull
  git -C "$PROJECT_DIR" checkout "$LATEST_BRANCH" --quiet 2>/dev/null || true
  git -C "$PROJECT_DIR" pull --quiet origin "$LATEST_BRANCH" 2>/dev/null || true

  # Show current state
  CURRENT_BRANCH=$(git -C "$PROJECT_DIR" symbolic-ref --short HEAD 2>/dev/null || echo "unknown")
  LAST_COMMIT=$(git -C "$PROJECT_DIR" log -1 --format="%h %s" 2>/dev/null || echo "no commits")
  ok "Branch: $CURRENT_BRANCH | $LAST_COMMIT"
fi

# ── 2. v34 Cursor rules ───────────────────────────────────────
section 2 "Install v34 Cursor rules"
if [[ ! -d "$V34_DIR/.cursor" ]]; then
  info "Extracting v34 zip..."
  [[ -f "$V34_ZIP" ]] || fail "v34 zip not found at $V34_ZIP"
  mkdir -p "$RKT_HOME/v34-tmp"
  unzip -q "$V34_ZIP" -d "$RKT_HOME/v34-tmp"
  SRC=$(find "$RKT_HOME/v34-tmp" -name "cursor.config" 2>/dev/null | head -1 | xargs dirname)
  [[ -n "$SRC" ]] || fail "cursor.config not found inside zip"
  mkdir -p "$V34_DIR"
  cp -r "$SRC/." "$V34_DIR/"
  rm -rf "$RKT_HOME/v34-tmp"
  ok "v34 extracted → $V34_DIR"
else
  ok "v34 already at $V34_DIR"
fi

mkdir -p "$PROJECT_DIR/.cursor"
cp -r "$V34_DIR/.cursor/." "$PROJECT_DIR/.cursor/"
RULE_COUNT=$(ls "$PROJECT_DIR/.cursor/rules/" 2>/dev/null | wc -l | tr -d ' ')
CMD_COUNT=$(ls "$PROJECT_DIR/.cursor/commands/" 2>/dev/null | wc -l | tr -d ' ')
ok "Installed: $RULE_COUNT rules, $CMD_COUNT commands"

[[ -d "$V34_DIR/memory-bank" ]] && cp -r "$V34_DIR/memory-bank" "$PROJECT_DIR/memory-bank" && ok "memory-bank skeleton"
for f in AGENTS.md TROUBLESHOOTING.md the-rocket-guide.md; do
  [[ -f "$V34_DIR/$f" ]] && cp "$V34_DIR/$f" "$PROJECT_DIR/$f"
done

# ── 3. Graphify ───────────────────────────────────────────────
section 3 "Graphify — context graph"
cd "$PROJECT_DIR"
if ! command -v graphify >/dev/null 2>&1; then
  info "Installing graphify..."
  pip install graphifyy --quiet 2>/dev/null || pip3 install graphifyy --quiet 2>/dev/null || warn "graphify install failed"
else
  ok "graphify already installed"
fi
if command -v graphify >/dev/null 2>&1; then
  graphify cursor install 2>/dev/null && ok "graphify → Cursor" || warn "graphify cursor failed"
  graphify claude install 2>/dev/null && ok "graphify → Claude Code" || warn "graphify claude failed"
  graphify hook install 2>/dev/null && ok "graphify git hooks" || warn "graphify hooks failed"
else
  skip "graphify not available"
fi

# ── 4. claude-mem ─────────────────────────────────────────────
section 4 "claude-mem — persistent session memory"
# claude-mem installs globally via Claude Code plugin system
# We add the install commands to a post-setup script the user runs once in Claude Code
PLUGIN_SETUP="$PROJECT_DIR/.claude/setup-plugins.md"
mkdir -p "$PROJECT_DIR/.claude"
cat > "$PLUGIN_SETUP" << 'PLUGEOF'
# Run these commands once inside Claude Code (open project, then run these)

## claude-mem — auto-captures session history
/plugin marketplace add thedotmack/claude-mem
/plugin install claude-mem

## Superpowers — TDD workflow, brainstorm→plan→implement
/plugin marketplace add obra/superpowers-marketplace
/plugin install superpowers@superpowers-marketplace
PLUGEOF
ok "Plugin setup instructions → .claude/setup-plugins.md"
info "Run these once inside Claude Code after opening project"

# ── 5. UI/UX Pro Max ──────────────────────────────────────────
section 5 "UI/UX Pro Max skill"
if ! command -v uipro >/dev/null 2>&1; then
  info "Installing uipro-cli..."
  npm install -g uipro-cli --quiet 2>/dev/null && ok "uipro-cli installed" || warn "uipro-cli install failed"
fi
if command -v uipro >/dev/null 2>&1; then
  cd "$PROJECT_DIR"
  uipro init --ai claude --force 2>/dev/null && ok "UI/UX Pro Max → Claude Code" || warn "uipro init failed"
  uipro init --ai cursor --force 2>/dev/null && ok "UI/UX Pro Max → Cursor" || warn "uipro cursor init failed"
else
  skip "uipro not available"
fi

# ── 5b. Copy global skills to project ────────────────────────
section "5b" "Global skills → project .claude/skills/"
mkdir -p "$PROJECT_DIR/.claude/skills"
for skill in graph review think memory ux obsidian; do
  if [[ -f "$HOME/.claude/skills/${skill}.md" ]]; then
    cp "$HOME/.claude/skills/${skill}.md" \
       "$PROJECT_DIR/.claude/skills/${skill}.md"
    ok "/${skill} skill copied"
  fi
done

# ── 6. MCP placeholder — merged after RuFlo (step 10) ────────
section 6 "MCP servers — queued for merge after RuFlo"
ok "Context7 + Sequential Thinking + Memory + Playwright queued"

# Write MCP config to .cursor/mcp.json for Cursor IDE
mkdir -p "$PROJECT_DIR/.cursor"
python3 - << PYEOF
import json, os

cursor_mcp = "$PROJECT_DIR/.cursor/mcp.json"

servers = {
    "context7": {"command": "npx", "args": ["-y", "@upstash/context7-mcp@latest"]},
    "sequential-thinking": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]},
    "memory": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"]},
    "playwright": {"command": "npx", "args": ["@playwright/mcp@latest"]}
}

existing = {}
if os.path.exists(cursor_mcp):
    try:
        with open(cursor_mcp) as f:
            existing = json.load(f)
    except Exception:
        existing = {}

if "mcpServers" not in existing:
    existing["mcpServers"] = {}

added = [k for k in servers if k not in existing["mcpServers"]]
existing["mcpServers"].update({k: v for k, v in servers.items() if k not in existing["mcpServers"]})

with open(cursor_mcp, "w") as f:
    json.dump(existing, f, indent=2)

if added:
    print(f"  \033[0;32m✓\033[0m MCP → .cursor/mcp.json ({', '.join(added)})")
else:
    print("  \033[0;32m✓\033[0m MCP → .cursor/mcp.json (already present)")
PYEOF

# ── 7. Detect project + generate CLAUDE.md ───────────────────
section 7 "Generate project-specific CLAUDE.md"
cd "$PROJECT_DIR"

# ── 7a. Run fingerprinter (engine) or fall back to bash heuristics ──
FP_TYPE="Unknown"; FP_CONFIDENCE="?"; FP_FAILURE="Unknown"
FP_CATEGORY="OTHER"; FP_FRAMEWORK="Next.js"; FP_NEXT_VERSION="unknown"
FP_HAS_SUPABASE="false"; FP_HAS_STRIPE="false"
FP_ENV_BLOCK=""; FP_SCORES_BLOCK=""; FP_SQL_FILES=0
KEY_FORMAT="legacy (anon_key)"

if $ENGINE_AVAILABLE; then
  info "Running engine fingerprinter..."
  FP_JSON=$("$ENGINE_VENV" "$ENGINE_FP" --json "$PROJECT_DIR" 2>/dev/null)

  if [[ -n "$FP_JSON" ]]; then
    FP_TYPE=$(echo "$FP_JSON"        | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('project_type','Unknown'))")
    FP_CONFIDENCE=$(echo "$FP_JSON"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(f\"{d.get('confidence',0):.0%}\")")
    FP_FAILURE=$(echo "$FP_JSON"     | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('common_failure',''))")
    FP_CATEGORY=$(echo "$FP_JSON"    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('category','OTHER'))")
    FP_FRAMEWORK=$(echo "$FP_JSON"   | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('framework','Next.js'))")
    FP_NEXT_VERSION=$(echo "$FP_JSON"| python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('next_version','') or 'unknown')")
    FP_HAS_SUPABASE=$(echo "$FP_JSON"| python3 -c "import sys,json; d=json.load(sys.stdin); print(str(d.get('has_supabase',False)).lower())")
    FP_HAS_STRIPE=$(echo "$FP_JSON"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(str(d.get('has_stripe',False)).lower())")
    FP_SQL_FILES=$(echo "$FP_JSON"   | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('sql_files_found',0))")
    FP_ENV_BLOCK=$(echo "$FP_JSON"   | python3 -c "
import sys,json
d=json.load(sys.stdin)
for k,v in d.get('env_vars',{}).items():
    mark = '✓' if v else '✗'
    print(f'  {mark} {k}')
")
    FP_SCORES_BLOCK=$(echo "$FP_JSON"| python3 -c "
import sys,json
d=json.load(sys.stdin)
items = sorted(d.get('all_scores',{}).items(), key=lambda x: -x[1])
for t,s in items:
    bar = '█' * int(s*20)
    print(f'  {t:<12} {s:.3f} {bar}')
")
    ok "Fingerprinted: $FP_TYPE ($FP_CONFIDENCE confidence) — most likely: $FP_FAILURE"
  else
    warn "Fingerprinter returned no output — falling back to bash heuristics"
  fi
fi

# Bash fallbacks (used if engine not available or returned empty)
[[ "$FP_NEXT_VERSION" == "unknown" ]] && \
  FP_NEXT_VERSION=$(grep '"next"' package.json 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
[[ "$FP_HAS_SUPABASE" == "false" ]] && \
  grep -q '"@supabase' package.json 2>/dev/null && FP_HAS_SUPABASE=true
[[ "$FP_HAS_STRIPE" == "false" ]] && \
  grep -q '"stripe"' package.json 2>/dev/null && FP_HAS_STRIPE=true

grep -q "sb_publishable_\|SUPABASE_PUBLISHABLE" .env .env.local 2>/dev/null && \
  KEY_FORMAT="new (sb_publishable_)"

# Additional feature flags via bash (supplements fingerprinter)
HAS_AUTH=false; HAS_REALTIME=false; HAS_STORAGE=false; HAS_AI=false
grep -rq 'getUser\|signIn\|signUp' app/ src/app/ 2>/dev/null && HAS_AUTH=true
grep -rq '\.channel\|realtime' app/ src/app/ 2>/dev/null && HAS_REALTIME=true
grep -rq 'storage\|\.upload' app/ src/app/ 2>/dev/null && HAS_STORAGE=true
grep -q '"openai"\|"@anthropic"\|"ai"' package.json 2>/dev/null && HAS_AI=true

FILE_COUNT=$(find app/ src/app/ -name "*.ts" -o -name "*.tsx" 2>/dev/null | wc -l | tr -d ' ')
HAS_MIDDLEWARE=$([[ -f middleware.ts || -f src/middleware.ts ]] && echo "YES — at root ✓" || echo "MISSING ✗")

FEATURES=""
[[ "$FP_HAS_SUPABASE" == "true" ]] && FEATURES="$FEATURES Supabase"
$HAS_AUTH      && FEATURES="$FEATURES Auth"
[[ "$FP_HAS_STRIPE" == "true" ]]   && FEATURES="$FEATURES Stripe"
$HAS_REALTIME  && FEATURES="$FEATURES Realtime"
$HAS_STORAGE   && FEATURES="$FEATURES Storage"
$HAS_AI        && FEATURES="$FEATURES AI"

# Extra rule for new Supabase key format
RULE9=""
[[ "$KEY_FORMAT" == "new (sb_publishable_)" ]] && \
  RULE9="9. New Supabase key: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (not ANON_KEY)"

# Failure modes block for this project type
FAILURE_MODES_BLOCK=""
case "$FP_TYPE" in
  SaaS)
    FAILURE_MODES_BLOCK="## Known Failure Modes (SaaS)
- **Stripe webhook 400** → request.json() used, change to request.text()
- **Dashboard blank after signup** → missing on_auth_user_created trigger
- **getSession() in server** → replace with getUser(), never getSession()"
    ;;
  E-Commerce)
    FAILURE_MODES_BLOCK="## Known Failure Modes (E-Commerce)
- **Order never confirmed** → no inventory decrement in webhook, only in client
- **RLS gap on orders** → orders table missing UPDATE policy for user_id check
- **Cart lost on refresh** → cart stored in local state, not Supabase"
    ;;
  AI)
    FAILURE_MODES_BLOCK="## Known Failure Modes (AI)
- **API quota exhausted** → no rate limiting on /api/chat route
- **Slow cold start** → model loaded on every request, use singleton
- **Conversation lost** → messages not persisted to Supabase between sessions"
    ;;
  Booking)
    FAILURE_MODES_BLOCK="## Known Failure Modes (Booking)
- **Double-booking** → no unique constraint on (resource_id, time_slot)
- **Timezone bug** → storing local time not UTC, breaks across timezones
- **Slot shown as free** → RLS prevents unauthenticated SELECT on slots"
    ;;
  Landing)
    FAILURE_MODES_BLOCK="## Known Failure Modes (Landing)
- **Contact form silent fail** → handleSubmit only sets local state, no API call
- **Leads table empty** → RLS policy missing, INSERT blocked for anon users
- **Newsletter signup 403** → subscribers table has no INSERT policy for anon"
    ;;
  Blog)
    FAILURE_MODES_BLOCK="## Known Failure Modes (Blog)
- **Sitemap 500** → sitemap.ts/xml missing or references unpublished posts
- **OG image broken** → dynamic OG route has missing font or fetch error
- **Posts not showing** → posts table has SELECT policy requiring auth, blocks anon"
    ;;
esac

info "Detected: $FP_FRAMEWORK ${FP_NEXT_VERSION:-?} |$FEATURES"

cat > "$PROJECT_DIR/CLAUDE.md" << CLAUDEEOF
# $PROJECT — Project Context
<!-- Generated by rkt-main + rkt-engine. In .gitignore — never committed. -->

## Project Intelligence
Type:           $FP_TYPE ($FP_CONFIDENCE confidence)
Framework:      $FP_FRAMEWORK ${FP_NEXT_VERSION:-?}
Has Supabase:   $FP_HAS_SUPABASE
Has Stripe:     $FP_HAS_STRIPE
SQL files:      $FP_SQL_FILES
Most likely bug: $FP_FAILURE
Failure category: $FP_CATEGORY

Type scores (all project types):
$FP_SCORES_BLOCK

Env var status:
$FP_ENV_BLOCK

## Stack
$FP_FRAMEWORK ${FP_NEXT_VERSION:-15} App Router (TypeScript) · Supabase @supabase/ssr · Tailwind CSS · Netlify
Files: $FILE_COUNT TypeScript/TSX in /app | middleware.ts: $HAS_MIDDLEWARE
Supabase key format: $KEY_FORMAT
Active features:$FEATURES

$FAILURE_MODES_BLOCK

## Hard Rules — Never Violate
1. \`getUser()\` not \`getSession()\` in server code — getSession() doesn't validate JWT
2. \`request.text()\` not \`request.json()\` in Stripe webhooks — always
3. \`middleware.ts\` at project root — never inside \`/app\`
4. \`@supabase/ssr\` only — never \`auth-helpers-nextjs\` (deprecated)
5. \`await cookies()\` — required in Next.js 15, not optional
6. Never \`NEXT_PUBLIC_\` on service role / secret keys
7. Never \`// ... existing code ...\` in diffs — Lazy Delete bug silently deletes code
8. \`export const dynamic = 'force-dynamic'\` on all authenticated pages
$RULE9

## Supabase Client — Which File
| Context | Import from |
|---|---|
| \`'use client'\` component | \`@/lib/supabase/client.ts\` |
| Server Component / Route Handler / Server Action | \`@/lib/supabase/server.ts\` |
| \`middleware.ts\` | \`@/lib/supabase/middleware.ts\` |

## MCP Servers Available
- **context7** — type "use context7" to get live docs for any library
- **sequential-thinking** — use for complex multi-step problems
- **memory** — persistent notes across sessions
- **playwright** — browser automation for testing OAuth/Stripe flows

## Slash Commands (v34)
\`/audit-codebase\` \`/fix-auth\` \`/fix-database\` \`/fix-stripe\` \`/fix-deployment\`
\`/implement-feature\` \`/plan-feature\` \`/spec-feature\` \`/debug-error\`
\`/security-audit\` \`/fix-performance\` \`/review-diff\` \`/refactor-safe\`

## Tools Active
- Graphify: context graph (PreToolUse hook — reads graph before file searches)
- claude-mem: auto-captures session history (globally installed)
- Superpowers: TDD workflow (install via .claude/setup-plugins.md)
- UI/UX Pro Max: design intelligence (auto-activates on UI requests)
- code-review-graph: structural map in code-review-graph/
- RuFlo V3: agent swarm + vector memory (.claude-flow/)
- Obsidian vault: $VAULT_DIR

## Protocol
1. State root cause before touching any code
2. List files changing + files NOT touching
3. One file at a time — show complete diff, wait for confirmation
4. Never produce ellipsis in diffs — show full file content
CLAUDEEOF

LINE_COUNT=$(wc -l < "$PROJECT_DIR/CLAUDE.md" | tr -d ' ')
ok "CLAUDE.md generated ($LINE_COUNT lines — project-specific with engine intelligence)"

# ── 8. code-review-graph ──────────────────────────────────────
section 8 "Build code-review-graph"
if command -v code-review-graph >/dev/null 2>&1; then
  cd "$PROJECT_DIR"
  code-review-graph build 2>/dev/null && ok "code-review-graph built" || warn "build failed — run manually"
else
  skip "code-review-graph not in PATH"
fi

# ── 9. Obsidian vault ─────────────────────────────────────────
section 9 "Setup Obsidian vault"
mkdir -p "$VAULT_DIR"/{Architecture,Features,Bugs,Decisions,Daily,.obsidian}

cat > "$VAULT_DIR/.obsidian/app.json" << 'OBSEOF'
{"useMarkdownLinks":false,"newLinkFormat":"shortest","attachmentFolderPath":"Assets"}
OBSEOF

cat > "$VAULT_DIR/index.md" << INDEXEOF
