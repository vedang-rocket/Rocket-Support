#!/usr/bin/env bash
# ============================================================
#  rkt-triage — Rocket.new Project Triage & Fix Orchestrator
#  Usage: rkt-triage <project.zip> ["issue description"]
#         rkt-triage --help
# ============================================================

RKT_HOME="${RKT_HOME:-$HOME/rocket-support}"
ENGINE_DIR="$RKT_HOME/engine"
PYTHON="$ENGINE_DIR/.venv/bin/python3"

GREEN=$'\033[0;32m'; BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'
YELLOW=$'\033[1;33m'; RED=$'\033[0;31m'; BOLD=$'\033[1m'; NC=$'\033[0m'

ok()      { echo -e "  ${GREEN}✓${NC} $1"; }
info()    { echo -e "  ${BLUE}▸${NC} $1"; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $1"; }
fail()    { echo -e "\n  ${RED}✗ ERROR:${NC} $1\n"; exit 1; }
section() { echo -e "\n${BOLD}${CYAN}── $1 ──${NC}"; }

# ── Help ─────────────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF

${BOLD}rkt-triage${NC} — Rocket.new Project Triage & Fix Orchestrator

${BOLD}USAGE${NC}
  rkt-triage <project.zip> ["issue description"]
  rkt-triage --help

${BOLD}ARGUMENTS${NC}
  project.zip           Path to the client project zip file
  issue description     Optional: describe the reported issue in quotes

${BOLD}EXAMPLES${NC}
  rkt-triage ~/Downloads/wedcraft.zip "auth broken after login"
  rkt-triage ~/Downloads/shop.zip "dashboard blank after signup"
  rkt-triage ~/Downloads/app.zip

${BOLD}WHAT IT DOES${NC}
  1. Validates the zip file exists
  2. Builds ~/Documents/Rocket/<project>/ folder structure:
       old/<project>.zip   — copy of original zip
       old/<project>/      — extracted original
       fixed/<project>/    — working copy (Cursor/Claude opens here)
  3. Runs bun install (silent)
  4. Runs full triage pipeline (fingerprint → chain_walker → semgrep → db lookup)
  5. Prints triage report with root cause and confidence
  6. Shows fix mode menu (AUTO / GUIDED / CLAUDE / MANUAL)
  7. Executes the selected fix mode

${BOLD}FIX MODES${NC}
  AUTO    Apply all high-confidence fixes automatically (--yes --non-interactive)
  GUIDED  Open Cursor IDE at fixed/<project>/
  CLAUDE  Launch Claude Code headless (--dangerously-skip-permissions)
  MANUAL  Interactive per-file review via rkt_smart.py

${BOLD}AFTER FIXING${NC}
  Run: rkt-deliver
  This zips fixed/<project>/ → fixed/<project>_fixed.zip

${BOLD}ENGINE${NC}
  Python venv : $PYTHON
  Engine dir  : $ENGINE_DIR

EOF
}

# ── Numbered menu (works reliably in all terminals) ───────────────────────────

select_option_with_default() {
    local default_idx="$1"
    shift
    local options=("$@")
    local num=${#options[@]}

    echo "" > /dev/tty
    for i in "${!options[@]}"; do
        local num_display=$((i+1))
        if [ "$i" -eq "$default_idx" ]; then
            printf "  \033[1;36m[%d] %s  ← recommended\033[0m\n" \
                "$num_display" "${options[$i]}" > /dev/tty
        else
            printf "  [%d] %s\n" "$num_display" "${options[$i]}" > /dev/tty
        fi
    done
    echo "" > /dev/tty

    local default_display=$((default_idx+1))
    printf "  Enter number [default %d]: " "$default_display" > /dev/tty

    local choice
    read -r choice < /dev/tty

    if [[ -z "$choice" ]]; then
        echo "$default_idx"
        return
    fi

    if [[ "$choice" =~ ^[0-9]+$ ]] && \
       [ "$choice" -ge 1 ] && [ "$choice" -le "$num" ]; then
        echo $((choice-1))
    else
        echo "$default_idx"
    fi
}

select_option() {
    select_option_with_default 0 "$@"
}

# ── Spinner ───────────────────────────────────────────────────────────────────

spinner_start() {
    local msg="$1"
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    echo -ne "  ${CYAN}${frames[0]}${NC}  $msg"
    (
        while true; do
            echo -ne "\r  ${CYAN}${frames[$((i % ${#frames[@]}))]}${NC}  $msg"
            sleep 0.08
            ((i++))
        done
    ) &
    SPINNER_PID=$!
}

spinner_stop() {
    if [[ -n "${SPINNER_PID:-}" ]]; then
        kill "$SPINNER_PID" 2>/dev/null
        wait "$SPINNER_PID" 2>/dev/null
        SPINNER_PID=""
        echo -ne "\r\033[2K"   # clear the spinner line
    fi
}

# ── Guards ────────────────────────────────────────────────────────────────────

[[ "$1" == "--help" || "$1" == "-h" ]] && { show_help; exit 0; }
[[ $# -lt 1 ]] && { show_help; exit 1; }

ZIP_PATH="$(realpath "$1" 2>/dev/null || echo "$1")"
ISSUE_DESC="${2:-}"

[[ ! -f "$ZIP_PATH" ]] && fail "Zip file not found: $ZIP_PATH"
[[ "$ZIP_PATH" != *.zip ]] && warn "File does not end in .zip — proceeding anyway"
[[ ! -x "$PYTHON" ]] && fail "Python venv not found at $PYTHON\n  Run: cd $RKT_HOME/engine && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"

# ── Step 1: Create workspace ──────────────────────────────────────────────────

section "Step 1/4  Creating workspace"
info "Zip:   $ZIP_PATH"
info "Issue: ${ISSUE_DESC:-"(no description)"}"

WORKSPACE_JSON=$("$PYTHON" - <<PYEOF
import sys, json
sys.path.insert(0, "$ENGINE_DIR")
from workspace import create_workspace
meta = create_workspace("$ZIP_PATH", """${ISSUE_DESC}""")
print(json.dumps(meta))
PYEOF
)

if [[ $? -ne 0 || -z "$WORKSPACE_JSON" ]]; then
    fail "workspace.create_workspace() failed"
fi

WORKSPACE_PATH=$(echo "$WORKSPACE_JSON" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['workspace_path'])")
WORKSPACE_NAME=$(echo "$WORKSPACE_JSON" | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['workspace_name'])")
PORT=$(echo "$WORKSPACE_JSON"          | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin)['port'])")

ok "Workspace: $WORKSPACE_NAME"
ok "Path:      $WORKSPACE_PATH"
ok "Port:      $PORT"

# ── Step 2: bun install ───────────────────────────────────────────────────────

section "Step 2/4  Installing dependencies"

if command -v bun &>/dev/null && [[ -f "$WORKSPACE_PATH/package.json" ]]; then
    spinner_start "bun install"
    bun install --cwd "$WORKSPACE_PATH" --silent 2>/dev/null
    BUN_EXIT=$?
    spinner_stop
    if [[ $BUN_EXIT -eq 0 ]]; then
        ok "bun install complete"
    else
        warn "bun install exited $BUN_EXIT — continuing"
    fi
elif [[ ! -f "$WORKSPACE_PATH/package.json" ]]; then
    warn "No package.json found — skipping bun install"
else
    warn "bun not found — skipping install (install from https://bun.sh)"
fi

# ── Step 3: Run triage pipeline ───────────────────────────────────────────────

section "Step 3/4  Running triage pipeline"
info "Analyzing project..."

TRIAGE_SUMMARY=$("$PYTHON" "$ENGINE_DIR/run_triage.py" \
    "$WORKSPACE_PATH" "$ISSUE_DESC" "$PORT" 2>/dev/null)

if [[ $? -ne 0 || -z "$TRIAGE_SUMMARY" ]]; then
    fail "run_triage.py failed"
fi

RESULT_FILE="/tmp/rkt_triage_result.json"
if [[ ! -f "$RESULT_FILE" ]]; then
    fail "Triage result file not found: $RESULT_FILE"
fi

RECOMMENDED_MODE=$(  "$PYTHON" -c "import sys,json; print(json.load(open('$RESULT_FILE'))['fix_mode'])")
CONFIDENCE=$(        "$PYTHON" -c "import sys,json; print(f\"{json.load(open('$RESULT_FILE'))['overall_confidence']:.0%}\")")
AUTO_COUNT=$(        "$PYTHON" -c "import sys,json; print(json.load(open('$RESULT_FILE'))['auto_fixable_count'])")

echo ""
echo "$TRIAGE_SUMMARY"

# ── Step 4: Fix mode menu ─────────────────────────────────────────────────────

section "Step 4/4  Select fix mode"
echo -e "  Recommended: ${BOLD}${CYAN}${RECOMMENDED_MODE}${NC}  (confidence ${CONFIDENCE}, ${AUTO_COUNT} auto-fixable)"
echo ""

MENU_OPTIONS=(
    "AUTO    — apply all high-confidence fixes automatically"
    "GUIDED  — open Cursor with context pre-loaded"
    "CLAUDE  — use Claude Code headless"
    "MANUAL  — show diffs, I decide per file"
)

# Map recommended mode to index
case "$RECOMMENDED_MODE" in
    AUTO)   DEFAULT_IDX=0 ;;
    GUIDED) DEFAULT_IDX=1 ;;
    CLAUDE) DEFAULT_IDX=2 ;;
    MANUAL) DEFAULT_IDX=3 ;;
    *)      DEFAULT_IDX=3 ;;
esac

SELECTED_IDX=$(select_option_with_default "$DEFAULT_IDX" "${MENU_OPTIONS[@]}")

case $SELECTED_IDX in
    0) CHOSEN_MODE="AUTO"   ;;
    1) CHOSEN_MODE="GUIDED" ;;
    2) CHOSEN_MODE="CLAUDE" ;;
    3) CHOSEN_MODE="MANUAL" ;;
    *) CHOSEN_MODE="MANUAL" ;;
esac

echo ""
ok "Selected: ${BOLD}${CHOSEN_MODE}${NC}"
echo ""

# ── Execute fix mode ──────────────────────────────────────────────────────────

case "$CHOSEN_MODE" in

    AUTO)
        info "Running rkt_smart.py with --yes --non-interactive..."
        RETRIAGE_TS=$(date +%s)
        "$PYTHON" "$ENGINE_DIR/rkt_smart.py" "$WORKSPACE_PATH" --yes --non-interactive
        echo ""
        # Collect files modified during the fix run, then re-triage them
        FIXED_FILES_JSON=$("$PYTHON" -c "
import os, json, time
ws = '$WORKSPACE_PATH'
ts = $RETRIAGE_TS
files = []
for root, dirs, fnames in os.walk(ws):
    dirs[:] = [d for d in dirs if d not in {'node_modules', '.next', '.git', '__pycache__', '.rkt_snapshot'}]
    for fn in fnames:
        if fn.endswith(('.ts', '.tsx', '.js', '.jsx', '.sql')):
            fp = os.path.join(root, fn)
            try:
                if os.path.getmtime(fp) >= ts:
                    files.append(fp)
            except OSError:
                pass
print(json.dumps(files))
")
        "$PYTHON" "$ENGINE_DIR/retriage.py" "$WORKSPACE_PATH" "$FIXED_FILES_JSON" "$ISSUE_DESC"
        echo ""
        echo -e "  ${GREEN}${BOLD}Fixes applied.${NC} Run: ${CYAN}rkt-deliver${NC} to package and deliver"
        ;;

    GUIDED)
        # Write issue desc to temp file to avoid newline/quoting issues in Python heredoc
        printf '%s' "$ISSUE_DESC" > /tmp/rkt_issue_desc.txt

        # Write Cursor prompt file
        "$PYTHON" - <<PYEOF
import json, os

result_file = "/tmp/rkt_triage_result.json"
workspace   = "$WORKSPACE_PATH"

try:
    data = json.load(open(result_file))
except Exception:
    data = {}

findings   = data.get("findings_scored", [])
summary    = data.get("summary", "")
category   = data.get("primary_category", "UNKNOWN")
confidence = data.get("overall_confidence", 0)

# Read issue description from temp file to safely handle newlines
try:
    issue_desc = open("/tmp/rkt_issue_desc.txt").read().strip()
except Exception:
    issue_desc = ""

lines = []
lines.append("# RKT Triage Findings — Paste this into Cursor chat")
lines.append("")
lines.append(f"**Issue:** {issue_desc}")
lines.append(f"**Category:** {category}")
lines.append(f"**Confidence:** {confidence:.0%}")
lines.append("")
lines.append("## What the system found:")
lines.append("")

for f in findings:
    mode = f.get("fix_mode", "?")
    cat  = f.get("category", "?")
    src  = f.get("source", "?")
    desc = f.get("description", "")
    lines.append(f"- [{mode}] [{cat}] ({src}): {desc}")

lines.append("")
lines.append("## Your task:")
lines.append("")
lines.append("Fix all the issues listed above. Follow these rules:")
lines.append("- getUser() not getSession() in server code")
lines.append("- request.text() not request.json() in Stripe webhooks")
lines.append("- middleware.ts at project root, never in /app")
lines.append("- @supabase/ssr only, never auth-helpers-nextjs")
lines.append("- await cookies() required in Next.js 15")
lines.append("- Never NEXT_PUBLIC_ on service role key")
lines.append("- Always export const dynamic = 'force-dynamic' on authenticated pages")
lines.append("")
lines.append("## Full triage summary:")
lines.append("")
lines.append(summary)

prompt_path = os.path.join(workspace, ".rkt_prompt.md")
with open(prompt_path, "w") as f:
    f.write("\n".join(lines))

print(f"Prompt written to {prompt_path}")
PYEOF

        # Open Cursor
        /usr/local/bin/cursor "$WORKSPACE_PATH"

        echo ""
        echo -e "  \033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo -e "  \033[1;33m  CURSOR IS OPEN\033[0m"
        echo -e "  \033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo ""
        echo "  In Cursor:"
        echo "  1. Open file: .rkt_prompt.md"
        echo "  2. Select all text (Cmd+A)"
        echo "  3. Paste into Cursor chat"
        echo "  4. Press Enter"
        echo ""
        echo "  When done: rkt-deliver"
        echo -e "  \033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        ;;

    CLAUDE)
        info "Launching Claude Code (headless)..."
        echo -e "  ${YELLOW}When done, type /exit and then run: ${CYAN}rkt-deliver${NC}"
        echo ""
        cd "$WORKSPACE_PATH" && claude --dangerously-skip-permissions
        ;;

    MANUAL)
        info "Starting interactive review..."
        "$PYTHON" "$ENGINE_DIR/rkt_smart.py" "$WORKSPACE_PATH"
        ;;

esac

# ── Handoff report + AI prompt ────────────────────────────────────────────────
"$PYTHON" "$ENGINE_DIR/handoff.py" "$WORKSPACE_PATH" "$ISSUE_DESC"

echo ""
echo -e "  ${BOLD}Working directory${NC}"
echo -e "  ${BLUE}▸${NC} cd   ${CYAN}$WORKSPACE_PATH${NC}"
echo -e "  ${BLUE}▸${NC} open ${CYAN}$WORKSPACE_PATH${NC}"
echo ""
echo -e "  When done: ${CYAN}rkt-deliver${NC}"
echo ""
